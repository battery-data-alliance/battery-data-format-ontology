{
  "@context": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/context",
  "@id": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/schema/vendors/neware_nda",
  "@type": "csvw:TableSchema",
  "dcterms:title": "Neware NDA/NDAX binary — BDF column mapping",
  "dcterms:description": "Maps column names produced by parsing Neware NDA and NDAX binary files to BDF canonical columns. These are not file-level text headers; they are the DataFrame column names returned by the NewareNDA or fastnda parsing library. IMPORTANT: Current is in milliamperes and capacity/energy in mAh/mWh in the raw parsed output; schema:unitCode documents the as-parsed unit.",
  "schema:producer": {
    "@type": "schema:Organization",
    "schema:name": "Neware Technology"
  },
  "dcterms:conformsTo": {
    "@id": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/1.0.0/schema"
  },
  "csvw:columns": [
    {
      "csvw:name": "test_time_second",
      "csvw:titles": [
        "Time",
        "total_time_s"
      ],
      "schema:unitCode": "s"
    },
    {
      "csvw:name": "voltage_volt",
      "csvw:titles": [
        "Voltage",
        "voltage_V"
      ]
    },
    {
      "csvw:name": "current_ampere",
      "csvw:titles": [
        "Current(mA)",
        "current_mA"
      ],
      "schema:unitCode": "mA"
    },
    {
      "csvw:name": "cycle_count",
      "csvw:titles": [
        "Cycle",
        "cycle_count"
      ],
      "csvw:datatype": {
        "csvw:base": "xsd:integer"
      }
    },
    {
      "csvw:name": "step_id",
      "csvw:titles": [
        "Step",
        "step_count",
        "Step_Index",
        "step_index"
      ]
    },
    {
      "csvw:name": "unix_time_second",
      "csvw:titles": [
        "unix_time_s"
      ]
    },
    {
      "csvw:name": "charging_capacity_ah",
      "csvw:titles": [
        "Charge_Capacity(mAh)"
      ],
      "schema:unitCode": "mA.h"
    },
    {
      "csvw:name": "discharging_capacity_ah",
      "csvw:titles": [
        "Discharge_Capacity(mAh)"
      ],
      "schema:unitCode": "mA.h"
    },
    {
      "csvw:name": "charging_energy_wh",
      "csvw:titles": [
        "Charge_Energy(mWh)"
      ],
      "schema:unitCode": "mW.h"
    },
    {
      "csvw:name": "discharging_energy_wh",
      "csvw:titles": [
        "Discharge_Energy(mWh)"
      ],
      "schema:unitCode": "mW.h"
    }
  ]
