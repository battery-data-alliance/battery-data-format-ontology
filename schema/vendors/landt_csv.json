{
  "@context": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/context",
  "@id": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/schema/vendors/landt_csv",
  "@type": "csvw:TableSchema",
  "dcterms:title": "LANDT CT-Series CSV — BDF column mapping",
  "dcterms:description": "Maps LANDT CT-series modern CSV export headers to BDF canonical columns. Modern LANDT exports use snake_case headers with SI units embedded in the name (e.g. test_time_s, voltage_v). All columns are already in BDF canonical SI units; no unit conversion is required.",
  "schema:producer": {
    "@type": "schema:Organization",
    "schema:name": "LANDT Instruments"
  },
  "dcterms:conformsTo": {
    "@id": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/1.0.0/schema"
  },
  "csvw:columns": [
    {
      "csvw:name": "test_time_second",
      "csvw:titles": [
        "test_time_s"
      ],
      "schema:unitCode": "s"
    },
    {
      "csvw:name": "step_time_second",
      "csvw:titles": [
        "step_time_s"
      ],
      "schema:unitCode": "s"
    },
    {
      "csvw:name": "voltage_volt",
      "csvw:titles": [
        "voltage_v"
      ]
    },
    {
      "csvw:name": "current_ampere",
      "csvw:titles": [
        "current_a"
      ]
    },
    {
      "csvw:name": "cycle_count",
      "csvw:titles": [
        "cycle_index"
      ],
      "csvw:datatype": {
        "csvw:base": "xsd:integer"
      }
    },
    {
      "csvw:name": "step_id",
      "csvw:titles": [
        "step_index"
      ]
    },
    {
      "csvw:name": "record_index",
      "csvw:titles": [
        "channel_index"
      ],
      "csvw:datatype": {
        "csvw:base": "xsd:integer"
      },
      "skos:note": "channel_index in LANDT CSV is a sequential record counter analogous to record_index."
    },
    {
      "csvw:name": "unix_time_second",
      "csvw:titles": [
        "date_time_iso_string"
      ],
      "csvw:datatype": {
        "csvw:base": "xsd:dateTime"
      },
      "skos:note": "ISO 8601 datetime string; converted to Unix epoch seconds by the BDF normaliser."
    }
  ]
}