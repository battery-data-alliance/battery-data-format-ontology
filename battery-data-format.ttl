                      rdfs:label "Charging Capacity / Ah"@en ;
                      skos:altLabel "charging_capacity_ah"@en ,
                                    "charging_capacity_ampere_hour"@en ;
                      skos:definition "Electric charge transferred into the test object during charging, in ampere hour."@en ;
                      skos:notation "charging_capacity_ah" ;
                      skos:prefLabel "Charging Capacity / Ah"@en ;
                      schema:description "Electric charge transferred into the test object during charging, in ampere hour."@en ;
                      schema:name "Charging Capacity / Ah"@en ;
                      emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Electric charge transferred into the test object during charging, in ampere hour."@en .


