#################################################################
#    Classes
#################################################################

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#ambient_pressure_pascal
:ambient_pressure_pascal rdf:type owl:Class ;
                         rdfs:subClassOf emmo:EMMO_50a44256_9dc5_434b_bad4_74a4d9a29989 ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                           owl:someValuesFrom emmo:Pascal
                                         ] ;
                         rdfs:comment "The ambient pressure, recorded in Pascal"@en ;
                         rdfs:label "Ambient Pressure / Pa"@en ;
                         skos:altLabel "ambient_pressure_pascal"@en ;
                         skos:prefLabel "Ambient Pressure / Pa"@en ;
                         schema:name "Ambient Pressure / Pa"@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#ambient_temperature_celsius
:ambient_temperature_celsius rdf:type owl:Class ;
                             rdfs:subClassOf emmo:EMMO_66bc9029_f473_45ff_bab9_c3509ff37a22 ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                               owl:someValuesFrom emmo:DegreeCelsius
                                             ] ;
                             rdfs:comment "The ambient temperature, recorded in degree Celsius"@en ;
                             rdfs:label "Ambient Temperature / degC"@en ;
                             skos:altLabel "ambient_temperature_celsius"@en ;
                             skos:prefLabel "Ambient Temperature / degC"@en ;
                             schema:name "Ambient Temperature / degC"@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#charging_capacity_ah
:charging_capacity_ah rdf:type owl:Class ;
                      rdfs:subClassOf electrochemistry:electrochemistry_10763eb0_dbc9_4d34_bd1a_7b8996590d45 ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                           owl:someValuesFrom emmo:AmpereHour
                                         ] ;
                      skos:prefLabel "Charging Capacity / Ah"@en ;
                      emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Electric charge transferred into the test object during charging, in ampere hour."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#charging_energy_wh
:charging_energy_wh rdf:type owl:Class ;
                    rdfs:subClassOf electrochemistry:electrochemistry_2ab7af60_da58_4243_b3bc_cbb2155cac53 ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                           owl:someValuesFrom emmo:AmpereHour
                                         ] ;
                    skos:prefLabel "Charging Energy / Wh"@en ;
                    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Energy transferred into the test object during charging, in watt hour."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cumulative_capacity_ah
:cumulative_capacity_ah rdf:type owl:Class ;
                        rdfs:subClassOf electrochemistry:electrochemistry_df9e9d49_12fa_4794_b482_e0dcd2a7bb66 ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                           owl:someValuesFrom emmo:AmpereHour
                                         ] ;
                        skos:prefLabel "Cumulative Capacity / Ah"@en ;
                        emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Total electric charge that has passed through the test object since the start of the test, in ampere hour."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cumulative_energy_wh
:cumulative_energy_wh rdf:type owl:Class ;
                      rdfs:subClassOf electrochemistry:electrochemistry_0f986d97_445f_4075_a5ce_ddde598a47a9 ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                           owl:someValuesFrom emmo:WattHour
                                         ] ;
                      skos:prefLabel "Cumulative Energy / Wh"@en ;
                      emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Total energy transferred through the test object since the start of the test, in watt hour."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#current_ampere
:current_ampere rdf:type owl:Class ;
                rdfs:subClassOf electrochemistry:electrochemistry_a24f8581_a5a4_41a4_bb45_d0fdd5c0d810 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                  owl:someValuesFrom emmo:Ampere
                                ] ;
                rdfs:comment "Instantaneous current, recorded in Ampere"@en ;
                rdfs:label "Current / A"@en ;
                skos:altLabel "current_ampere"@en ;
                skos:prefLabel "Current / A"@en ;
                schema:name "Current / A"@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_count
:cycle_count rdf:type owl:Class ;
             rdfs:subClassOf electrochemistry:electrochemistry_5766a819_c319_48ba_ab9a_ce3bd8fedee8 ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                               owl:someValuesFrom emmo:EMMO_5ebd5e01_0ed3_49a2_a30d_cd05cbe72978
                             ] ;
             rdfs:comment "The cycle number here is used to segregate data into smaller quasi-periodic subsets, and is typically used to track evolution of performance metrics over the course of aging."@en ;
             rdfs:label "Cycle / 1"@en ;
             skos:altLabel "cycle_count"@en ;
             skos:prefLabel "Cycle / 1"@en ;
             schema:name "Cycle / 1"@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#discharging_capacity_ah
:discharging_capacity_ah rdf:type owl:Class ;
