             skos:notation "cycle_count" ;
             skos:prefLabel "Cycle Count / 1"@en ;
             schema:description "The cycle number here is used to segregate data into smaller quasi-periodic subsets, and is typically used to track evolution of performance metrics over the course of aging."@en ;
             schema:name "Cycle Count / 1"@en ;
             emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "The cycle number here is used to segregate data into smaller quasi-periodic subsets, and is typically used to track evolution of performance metrics over the course of aging."@en .


