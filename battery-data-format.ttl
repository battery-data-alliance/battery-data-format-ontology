###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#phase_degree
:phase_degree rdf:type owl:Class ;
              rdfs:subClassOf emmo:EMMO_2a0e5777_348c_475b_adf0_1b1e71a29bc9 ;
              skos:altLabel "phase_degree"@en ;
              skos:definition "the phase angle of the complex impedance in electrochemical impedance spectroscopy, defined as the argument of the impedance and representing the phase relationship between voltage and current, expressed in degrees"@en ;
              skos:notation "phase_degree"@en ;
              skos:prefLabel "Phase / deg"@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#power_watt
:power_watt rdf:type owl:Class ;
            rdfs:subClassOf electrochemistry:electrochemistry_5973f91a_fa6b_49c9_ba46_3ecc1c2253d2 ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                              owl:someValuesFrom emmo:Watt
                            ] ;
            rdfs:comment "Instantaneous power calculated as the product of voltage and current, in watt."@en ;
            rdfs:label "Power / W"@en ;
            skos:altLabel "power_w"@en ,
                          "power_watt"@en ;
            skos:definition "Instantaneous power calculated as the product of voltage and current, in watt."@en ;
            skos:notation "power_watt" ;
            skos:prefLabel "Power / W"@en ;
