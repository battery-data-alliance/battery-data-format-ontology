:step_capacity_ah rdf:type owl:Class ;
                  rdfs:subClassOf sosa:ObservableProperty ,
                                  electrochemistry:electrochemistry_ae108db7_8765_4329_9908_059277dee586 ,
                                  [ rdf:type owl:Restriction ;
