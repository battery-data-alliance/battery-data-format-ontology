                         skos:exactMatch quantitykind:ElectricResistance ;
                         skos:hiddenLabel "Internal Resistance / Ohm"@en ;
                         skos:notation "internal_resistance_ohm" ;
                         :latexSymbol "R_\\mathrm{int}"^^xsd:string ;
                         :obligation "optional" ;
