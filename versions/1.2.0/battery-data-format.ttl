###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#step_type
:step_type rdf:type owl:Class ;
           rdfs:subClassOf sosa:ObservableProperty ,
                           emmo:EMMO_5f334606_f67d_4f0e_acb9_eeb21cb10c66 ;
           rdfs:comment "A string label describing the operational mode of the current test step, as reported by the cycler software. Common values include CC_CHG (constant-current charge), CC_DCH (constant-current discharge), CV_CHG (constant-voltage charge), CCCV_CHG (constant-current constant-voltage charge), REST, OCV, and EIS. The controlled vocabulary for this field is not yet standardised; values should be preserved as reported by the instrument."@en ;
           rdfs:label "Step Type"@en ;
           skos:altLabel "step_type"@en ;
           skos:definition "A string label describing the operational mode of the current test step, as reported by the cycler software. Common values include CC_CHG (constant-current charge), CC_DCH (constant-current discharge), CV_CHG (constant-voltage charge), CCCV_CHG (constant-current constant-voltage charge), REST, OCV, and EIS. The controlled vocabulary for this field is not yet standardised; values should be preserved as reported by the instrument."@en ;
           skos:notation "step_type" ;
           :obligation "optional" ;
           skos:prefLabel "Step Type"@en ;
           schema:description "A string label describing the operational mode of the current test step, as reported by the cycler software. Common values include CC_CHG, CC_DCH, CV_CHG, CCCV_CHG, REST, OCV, EIS."@en ;
           schema:name "Step Type"@en ;
           emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "A string label describing the operational mode of the current test step, as reported by the cycler software. Common values include CC_CHG (constant-current charge), CC_DCH (constant-current discharge), CV_CHG (constant-voltage charge), CCCV_CHG (constant-current constant-voltage charge), REST, OCV, and EIS. The controlled vocabulary for this field is not yet standardised; values should be preserved as reported by the instrument."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#surface_pressure_pa
:surface_pressure_pa rdf:type owl:Class ;
                     rdfs:subClassOf sosa:ObservableProperty ,
                                     emmo:EMMO_50a44256_9dc5_434b_bad4_74a4d9a29989 ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                       owl:someValuesFrom emmo:Pascal
                                     ] ;
                     rdfs:comment "Pressure measured at the surface of the test object, in pascal. A measured quantity that may be nonzero even when no external pressure is actively applied, e.g. from cell swelling against a fixture. Distinguished from applied_pressure_pa, which is actively applied and controlled by an external agent."@en ;
                     rdfs:label "Surface Pressure / Pa"@en ;
                     rdfs:seeAlso unit:PA ;
                     skos:altLabel "surface_pressure_pa"@en ,
                                   "surface_pressure_pascal"@en ;
                     skos:definition "Pressure measured at the surface of the test object, in pascal. A measured quantity that may be nonzero even when no external pressure is actively applied, e.g. from cell swelling against a fixture. Distinguished from applied_pressure_pa, which is actively applied and controlled by an external agent."@en ;
                     skos:exactMatch quantitykind:Pressure ;
                     skos:notation "surface_pressure_pa" ;
                     :latexSymbol "p_\\mathrm{surf}"^^xsd:string ;
                     :obligation "optional" ;
                     skos:prefLabel "Surface Pressure / Pa"@en ;
                     schema:description "Pressure measured at the surface of the test object, in pascal. A measured quantity that may be nonzero even when no external pressure is actively applied, e.g. from cell swelling against a fixture. Distinguished from applied_pressure_pa, which is actively applied and controlled by an external agent."@en ;
                     schema:name "Surface Pressure / Pa"@en ;
                     schema:unitCode "Pa" ;
                     schema:unitText "pascal"@en ;
                     emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Pressure measured at the surface of the test object, in pascal. A measured quantity that may be nonzero even when no external pressure is actively applied, e.g. from cell swelling against a fixture. Distinguished from applied_pressure_pa, which is actively applied and controlled by an external agent."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#surface_temperature_celsius
:surface_temperature_celsius rdf:type owl:Class ;
                             rdfs:subClassOf sosa:ObservableProperty ,
                                             emmo:EMMO_66bc9029_f473_45ff_bab9_c3509ff37a22 ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                               owl:someValuesFrom emmo:DegreeCelsius
                                             ] ;
                             rdfs:comment "Temperature measured at the surface of the test object, in degree Celsius, regardless of which sensor channel recorded it. Use this term when a column is explicitly a surface (skin) temperature without channel information; channel-indexed auxiliary sensors map to temperature_t1_celsius through temperature_t5_celsius, whose placement is setup-defined."@en ;
                             rdfs:label "Surface Temperature / degC"@en ;
                             rdfs:seeAlso unit:DEG_C ;
                             skos:altLabel "surface_temperature_celsius"@en ,
                                           "surface_temperature_degc"@en ;
                             skos:definition "Temperature measured at the surface of the test object, in degree Celsius, regardless of which sensor channel recorded it. Use this term when a column is explicitly a surface (skin) temperature without channel information; channel-indexed auxiliary sensors map to temperature_t1_celsius through temperature_t5_celsius, whose placement is setup-defined."@en ;
                             skos:exactMatch quantitykind:Temperature ;
                             skos:notation "surface_temperature_celsius" ;
                             :latexSymbol "T_\\mathrm{surf}"^^xsd:string ;
                             :obligation "optional" ;
                             skos:prefLabel "Surface Temperature / degC"@en ;
                             schema:description "Temperature measured at the surface of the test object, in degree Celsius, regardless of sensor channel."@en ;
                             schema:name "Surface Temperature / degC"@en ;
                             schema:unitCode "Cel" ;
                             schema:unitText "degree Celsius"@en ;
                             emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Temperature measured at the surface of the test object, in degree Celsius, regardless of which sensor channel recorded it. Use this term when a column is explicitly a surface (skin) temperature without channel information; channel-indexed auxiliary sensors map to temperature_t1_celsius through temperature_t5_celsius, whose placement is setup-defined."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#temperature_t1_celsius
:temperature_t1_celsius rdf:type owl:Class ;
                        rdfs:subClassOf sosa:ObservableProperty ,
                                        emmo:EMMO_66bc9029_f473_45ff_bab9_c3509ff37a22 ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                          owl:someValuesFrom emmo:DegreeCelsius
                                        ] ;
                        rdfs:comment "Temperature recorded by auxiliary temperature channel 1 of the test setup, in degree Celsius. Sensor placement (e.g. cell surface, terminal, or elsewhere) is setup-defined and not constrained by this term; record the placement in accompanying metadata. Where a channel is known to measure the surface temperature of the test object, see also surface_temperature_celsius."@en ;
                        rdfs:label "Temperature T1 / degC"@en ;
                        rdfs:seeAlso unit:DEG_C ;
                        skos:altLabel "Surface Temperature T1 / degC"@en ,
                                      "surface_temperature_t1_celsius"@en ,
                                      "temperature_t1_celsius"@en ,
                                      "temperature_t1_degc"@en ;
                        skos:definition "Temperature recorded by auxiliary temperature channel 1 of the test setup, in degree Celsius. Sensor placement (e.g. cell surface, terminal, or elsewhere) is setup-defined and not constrained by this term; record the placement in accompanying metadata. Where a channel is known to measure the surface temperature of the test object, see also surface_temperature_celsius."@en ;
                        skos:exactMatch quantitykind:Temperature ;
                        skos:notation "temperature_t1_celsius" ;
                        skos:scopeNote "Default mapping convention: a single unqualified temperature column from a cycler, or an unqualified numbered channel (T1), maps to temperature_t1_celsius. Columns explicitly designated as chamber, environment, or ambient temperature map to ambient_temperature_celsius; columns explicitly designated as surface (skin) temperature without channel information map to surface_temperature_celsius."@en ;
                        :latexSymbol "T_1"^^xsd:string ;
                        :obligation "optional" ;
                        skos:prefLabel "Temperature T1 / degC"@en ;
                        schema:description "Temperature recorded by auxiliary temperature channel 1, in degree Celsius. Sensor placement is setup-defined; record it in accompanying metadata."@en ;
                        schema:name "Temperature T1 / degC"@en ;
                        schema:unitCode "Cel" ;
                        schema:unitText "degree Celsius"@en ;
                        emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Temperature recorded by auxiliary temperature channel 1 of the test setup, in degree Celsius. Sensor placement (e.g. cell surface, terminal, or elsewhere) is setup-defined and not constrained by this term; record the placement in accompanying metadata. Where a channel is known to measure the surface temperature of the test object, see also surface_temperature_celsius."@en .


