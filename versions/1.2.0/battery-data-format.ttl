                         schema:description "Internal resistance of the test object, in ohm, as reported by the instrument; the determination method is unspecified. Where the determination method is known, use the more specific dc_internal_resistance_ohm or ac_internal_resistance_ohm."@en ;
                         schema:name "Internal Resistance / ohm"@en ;
                         schema:unitCode "Ohm" ;
