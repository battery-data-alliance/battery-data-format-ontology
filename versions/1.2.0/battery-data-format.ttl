###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#unix_time_second
:unix_time_second rdf:type owl:Class ;
                  rdfs:subClassOf sosa:ObservableProperty ,
                                  electrochemistry:electrochemistry_27b3799c_250c_4332_8b71_7992c4a7bb05 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                    owl:someValuesFrom emmo:Second
                                  ] ;
                  rdfs:comment "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en ;
                  rdfs:label "Unix Time / s"@en ;
                  rdfs:seeAlso unit:SEC ;
                  skos:altLabel "unix_time_s"@en ,
                                "unix_time_second"@en ;
                  skos:definition "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en ;
                  skos:exactMatch quantitykind:Time ;
                  skos:notation "unix_time_second" ;
                  skos:scopeNote "A common conversion error is computing seconds since the epoch from a naive local wall-clock timestamp as if it were UTC, which shifts all values by the local UTC offset (including daylight-saving changes mid-test). Instruments that log local time must have their timestamps converted to UTC, not reinterpreted."@en ;
                  :latexSymbol "t_\\mathrm{unix}"^^xsd:string ;
                  :obligation "recommended" ;
                  skos:prefLabel "Unix Time / s"@en ;
                  schema:description "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en ;
                  schema:name "Unix Time / s"@en ;
                  schema:unitCode "s" ;
                  schema:unitText "second"@en ;
                  emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en .


