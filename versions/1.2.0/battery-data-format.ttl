@prefix : <https://w3id.org/battery-data-alliance/ontology/battery-data-format#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix emmo: <https://w3id.org/emmo#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix quantitykind: <http://qudt.org/vocab/quantitykind/> .
@prefix electrochemistry: <https://w3id.org/emmo/domain/electrochemistry#> .
@base <https://w3id.org/battery-data-alliance/ontology/battery-data-format#> .

<https://w3id.org/battery-data-alliance/ontology/battery-data-format> rdf:type owl:Ontology ;
                                                                       owl:versionIRI <https://w3id.org/battery-data-alliance/ontology/battery-data-format/1.2.0/battery-data-format> ;
                                                                       owl:imports <https://w3id.org/emmo/domain/battery/0.18.6/battery> ;
                                                                       dcterms:abstract "An application ontology for the Battery Data Format (BDF) from the Battery Data Alliance (BDA)" ;
                                                                       dcterms:bibliographicCitation "Pending" ;
                                                                       dcterms:created "2025-01-23"^^xsd:date ;
                                                                       dcterms:creator <https://orcid.org/0000-0002-8758-6109> ;
                                                                       dcterms:issued "2026-05-14"^^xsd:date ;
                                                                       dcterms:license <http://www.apache.org/licenses/LICENSE-2.0> ;
                                                                       dcterms:modified "2026-06-11"^^xsd:date ;
                                                                       dcterms:publisher "Battery Data Alliance" ;
                                                                       dcterms:title "Battery Data Format Ontology"@en ;
                                                                       bibo:doi "pending" ;
                                                                       bibo:status "stable" ;
                                                                       vann:preferredNamespacePrefix "bdf" ;
                                                                       vann:preferredNamespaceUri "https://w3id.org/battery-data-alliance/ontology/battery-data-format#" ;
                                                                       owl:priorVersion <https://w3id.org/battery-data-alliance/ontology/battery-data-format/1.1.0/battery-data-format> ;
                                                                       owl:versionInfo "1.2.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/isReplacedBy
dcterms:isReplacedBy rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/replaces
dcterms:replaces rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/doi
bibo:doi rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/status
bibo:status rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#historyNote
skos:historyNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#notation
skos:notation rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasRevisionOf
prov:wasRevisionOf rdf:type owl:AnnotationProperty .


###  https://schema.org/description
schema:description rdf:type owl:AnnotationProperty .


###  https://schema.org/measurementTechnique
schema:measurementTechnique rdf:type owl:AnnotationProperty .


###  https://schema.org/unitCode
schema:unitCode rdf:type owl:AnnotationProperty .


###  https://schema.org/unitText
schema:unitText rdf:type owl:AnnotationProperty .



###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#obligation
:obligation rdf:type owl:AnnotationProperty ;
            rdfs:label "obligation"@en ;
            rdfs:comment "Conformance level of this term within the default BDF profile (required, recommended, or optional). Obligation is profile-scoped; this annotation expresses the default profile only."@en ;
            rdfs:range xsd:string .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#latexFormula
:latexFormula rdf:type owl:AnnotationProperty ;
              rdfs:label "LaTeX formula"@en ;
              rdfs:comment "Mathematical definition of a derived quantity in LaTeX notation. Backslashes are single (standard LaTeX)."@en ;
              rdfs:range xsd:string .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#latexSymbol
:latexSymbol rdf:type owl:AnnotationProperty ;
             rdfs:label "LaTeX symbol"@en ;
             rdfs:comment "LaTeX notation for the variable name used to represent this quantity in mathematical expressions."@en ;
             rdfs:range xsd:string .

#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/sosa/ObservableProperty
sosa:ObservableProperty rdf:type owl:Class .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#absolute_impedance_ohm
:absolute_impedance_ohm rdf:type owl:Class ;
                        rdfs:subClassOf sosa:ObservableProperty ,
                                        emmo:EMMO_79a02de5_b884_4eab_bc18_f67997d597a2 ;
                        rdfs:seeAlso unit:OHM ;
                        skos:altLabel "absolute_impedance_ohm"@en ;
                        skos:definition "The magnitude of the complex impedance, in ohm."@en ;
                        skos:exactMatch quantitykind:Impedance ;
                        skos:notation "absolute_impedance_ohm"@en ;
                        :latexSymbol "|Z|"^^xsd:string ;
                        :latexFormula "|Z| = \\sqrt{Z_\\mathrm{re}^2 + Z_\\mathrm{im}^2}"^^xsd:string ;
                        :obligation "optional" ;
                        skos:prefLabel "Absolute Impedance / ohm"@en ;
                        schema:description "The magnitude of the complex impedance, in ohm."@en ;
                        prov:wasDerivedFrom :imaginary_impedance_ohm ,
                                            :real_impedance_ohm ;
                        schema:unitCode "Ohm" ;
                        schema:unitText "ohm"@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#ac_internal_resistance_ohm
:ac_internal_resistance_ohm rdf:type owl:Class ;
                            rdfs:subClassOf sosa:ObservableProperty ,
                                            :internal_resistance_ohm ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                              owl:someValuesFrom emmo:Ohm
                                            ] ;
                            rdfs:comment "Alternating current internal resistance of the test object, in ohm: the magnitude of the impedance at a fixed excitation frequency, conventionally 1 kHz unless otherwise stated. Equivalent to the ACR quantity reported by some instruments (e.g. Arbin ACR). The excitation frequency should be recorded in accompanying metadata."@en ;
                            rdfs:label "AC Internal Resistance / ohm"@en ;
                            rdfs:seeAlso unit:OHM ;
                            skos:altLabel "ac_internal_resistance_ohm"@en ,
                                          "ac_resistance_ohm"@en ,
                                          "acr"@en ;
                            skos:definition "Alternating current internal resistance of the test object, in ohm: the magnitude of the impedance at a fixed excitation frequency, conventionally 1 kHz unless otherwise stated. Equivalent to the ACR quantity reported by some instruments (e.g. Arbin ACR). The excitation frequency should be recorded in accompanying metadata."@en ;
                            skos:exactMatch quantitykind:Resistance ;
                            skos:notation "ac_internal_resistance_ohm" ;
                            :latexSymbol "R_\\mathrm{AC}"^^xsd:string ;
                            :obligation "optional" ;
                            skos:prefLabel "AC Internal Resistance / ohm"@en ;
                            schema:description "AC internal resistance: impedance magnitude at a fixed excitation frequency, conventionally 1 kHz. Equivalent to instrument ACR outputs."@en ;
                            schema:name "AC Internal Resistance / ohm"@en ;
                            schema:unitCode "Ohm" ;
                            schema:unitText "ohm"@en ;
                            emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Alternating current internal resistance of the test object, in ohm: the magnitude of the impedance at a fixed excitation frequency, conventionally 1 kHz unless otherwise stated. Equivalent to the ACR quantity reported by some instruments (e.g. Arbin ACR). The excitation frequency should be recorded in accompanying metadata."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#ambient_pressure_pa
:ambient_pressure_pa rdf:type owl:Class ;
                     rdfs:subClassOf sosa:ObservableProperty ,
                                     emmo:EMMO_50a44256_9dc5_434b_bad4_74a4d9a29989 ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                       owl:someValuesFrom emmo:Pascal
                                     ] ;
                     rdfs:comment "Ambient air pressure recorded during testing, in pascal."@en ;
                     rdfs:label "Ambient Pressure / Pa"@en ;
                     rdfs:seeAlso unit:PA ;
                     skos:altLabel "ambient_pressure_pa"@en ,
                                   "ambient_pressure_pascal"@en ;
                     skos:definition "Ambient air pressure recorded during testing, in pascal."@en ;
                     skos:exactMatch quantitykind:Pressure ;
                     skos:notation "ambient_pressure_pa" ;
                     :latexSymbol "p_\\mathrm{amb}"^^xsd:string ;
                     :obligation "optional" ;
                     skos:prefLabel "Ambient Pressure / Pa"@en ;
                     schema:description "Ambient air pressure recorded during testing, in pascal."@en ;
                     schema:name "Ambient Pressure / Pa"@en ;
                     schema:unitCode "Pa" ;
                     schema:unitText "pascal"@en ;
                     emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Ambient air pressure recorded during testing, in pascal."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#ambient_temperature_celsius
:ambient_temperature_celsius rdf:type owl:Class ;
                             rdfs:subClassOf sosa:ObservableProperty ,
                                             emmo:EMMO_66bc9029_f473_45ff_bab9_c3509ff37a22 ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                               owl:someValuesFrom emmo:DegreeCelsius
                                             ] ;
                             rdfs:comment "Ambient temperature recorded during testing, in degree Celsius."@en ;
                             rdfs:label "Ambient Temperature / degC"@en ;
                             rdfs:seeAlso unit:DEG_C ;
                             skos:altLabel "ambient_temperature_celsius"@en ,
                                           "ambient_temperature_degc"@en ;
                             skos:definition "Ambient temperature recorded during testing, in degree Celsius."@en ;
                             skos:exactMatch quantitykind:Temperature ;
                             skos:notation "ambient_temperature_celsius" ;
                             :latexSymbol "T_\\mathrm{amb}"^^xsd:string ;
                             :obligation "recommended" ;
                             skos:prefLabel "Ambient Temperature / degC"@en ;
                             schema:description "Ambient temperature recorded during testing, in degree Celsius."@en ;
                             schema:name "Ambient Temperature / degC"@en ;
                             schema:unitCode "Cel" ;
                             schema:unitText "degree Celsius"@en ;
                             emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Ambient temperature recorded during testing, in degree Celsius."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#applied_pressure_pa
:applied_pressure_pa rdf:type owl:Class ;
                     rdfs:subClassOf sosa:ObservableProperty ,
                                     emmo:EMMO_50a44256_9dc5_434b_bad4_74a4d9a29989 ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                       owl:someValuesFrom emmo:Pascal
                                     ] ;
                     rdfs:comment "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en ;
                     rdfs:label "Applied Pressure / Pa"@en ;
                     rdfs:seeAlso unit:PA ;
                     skos:altLabel "applied_pressure_pa"@en ,
                                   "applied_pressure_pascal"@en ;
                     skos:definition "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en ;
                     skos:exactMatch quantitykind:Pressure ;
                     skos:notation "applied_pressure_pa" ;
                     :latexSymbol "p_\\mathrm{app}"^^xsd:string ;
                     :obligation "optional" ;
                     skos:prefLabel "Applied Pressure / Pa"@en ;
                     schema:description "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en ;
                     schema:name "Applied Pressure / Pa"@en ;
                     schema:unitCode "Pa" ;
                     schema:unitText "pascal"@en ;
                     emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#charging_capacity_ah
:charging_capacity_ah rdf:type owl:Class ;
                      rdfs:subClassOf sosa:ObservableProperty ,
                                      electrochemistry:electrochemistry_10763eb0_dbc9_4d34_bd1a_7b8996590d45 ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                        owl:someValuesFrom emmo:AmpereHour
                                      ] ;
                      rdfs:comment "Cumulative electric charge transferred into the test object during charging, in ampere hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during charge intervals; unchanged during rest or discharge. Note: differs from step-level Q charge as reported by some instruments (e.g. BioLogic EC-Lab), which reset to zero at each step boundary."@en ;
                      rdfs:label "Charging Capacity / Ah"@en ;
                      rdfs:seeAlso unit:A-HR ;
                      skos:altLabel "charging_capacity_ah"@en ,
                                    "charging_capacity_ampere_hour"@en ;
                      skos:definition "Cumulative electric charge transferred into the test object during charging, in ampere hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during charge intervals; unchanged during rest or discharge. Note: differs from step-level Q charge as reported by some instruments (e.g. BioLogic EC-Lab), which reset to zero at each step boundary."@en ;
                      skos:exactMatch quantitykind:ElectricCharge ;
                      skos:notation "charging_capacity_ah" ;
                      :latexSymbol "Q_\\mathrm{chg}"^^xsd:string ;
                      :latexFormula "Q_\\mathrm{chg}(t) = \\frac{1}{3600}\\int_0^t \\max\\!\\bigl(I(\\tau),\\,0\\bigr)\\,\\mathrm{d}\\tau"^^xsd:string ;
                      :obligation "optional" ;
                      skos:prefLabel "Charging Capacity / Ah"@en ;
                      prov:wasDerivedFrom :current_ampere ,
                                          :test_time_second ;
                      schema:description "Cumulative electric charge transferred into the test object during charging since test start, in ampere hour. Never resets between steps or cycles."@en ;
                      schema:name "Charging Capacity / Ah"@en ;
                      schema:unitCode "A.h" ;
                      schema:unitText "ampere hour"@en ;
                      emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Cumulative electric charge transferred into the test object during charging, in ampere hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during charge intervals; unchanged during rest or discharge. Note: differs from step-level Q charge as reported by some instruments (e.g. BioLogic EC-Lab), which reset to zero at each step boundary."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#charging_energy_wh
:charging_energy_wh rdf:type owl:Class ;
                    rdfs:subClassOf sosa:ObservableProperty ,
                                    electrochemistry:electrochemistry_2ab7af60_da58_4243_b3bc_cbb2155cac53 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                      owl:someValuesFrom emmo:WattHour
                                    ] ;
                    rdfs:comment "Cumulative energy transferred into the test object during charging, in watt hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during charge intervals; unchanged during rest or discharge."@en ;
                    rdfs:label "Charging Energy / Wh"@en ;
                    rdfs:seeAlso unit:W-HR ;
                    skos:altLabel "charging_energy_watt_hour"@en ,
                                  "charging_energy_wh"@en ;
                    skos:definition "Cumulative energy transferred into the test object during charging, in watt hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during charge intervals; unchanged during rest or discharge."@en ;
                    skos:exactMatch quantitykind:Energy ;
                    skos:notation "charging_energy_wh" ;
                    :latexSymbol "E_\\mathrm{chg}"^^xsd:string ;
                    :latexFormula "E_\\mathrm{chg}(t) = \\frac{1}{3600}\\int_0^t P(\\tau)\\,\\bigl[I(\\tau) > 0\\bigr]\\,\\mathrm{d}\\tau,\\quad [\\cdot] = \\text{1 if true, 0 otherwise}"^^xsd:string ;
                    :obligation "optional" ;
                    skos:prefLabel "Charging Energy / Wh"@en ;
                    prov:wasDerivedFrom :power_watt ,
                                        :test_time_second ;
                    schema:description "Cumulative energy transferred into the test object during charging since test start, in watt hour. Never resets between steps or cycles."@en ;
                    schema:name "Charging Energy / Wh"@en ;
                    schema:unitCode "W.h" ;
                    schema:unitText "watt hour"@en ;
                    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Cumulative energy transferred into the test object during charging, in watt hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during charge intervals; unchanged during rest or discharge."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cumulative_capacity_ah
:cumulative_capacity_ah rdf:type owl:Class ;
                        rdfs:subClassOf sosa:ObservableProperty ,
                                        electrochemistry:electrochemistry_df9e9d49_12fa_4794_b482_e0dcd2a7bb66 ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                          owl:someValuesFrom emmo:AmpereHour
                                        ] ;
                        rdfs:comment "Total Ah throughput since the start of the test, in ampere hour. Defined as charging_capacity_ah + discharging_capacity_ah; always monotonically non-decreasing. Counts charge flow in both directions and is therefore independent of the net state of charge."@en ;
                        rdfs:label "Cumulative Capacity / Ah"@en ;
                        rdfs:seeAlso unit:A-HR ;
                        skos:altLabel "cumulative_capacity_ah"@en ,
                                      "cumulative_capacity_ampere_hour"@en ;
                        skos:definition "Total Ah throughput since the start of the test, in ampere hour. Defined as charging_capacity_ah + discharging_capacity_ah; always monotonically non-decreasing. Counts charge flow in both directions and is therefore independent of the net state of charge."@en ;
                        skos:exactMatch quantitykind:ElectricCharge ;
                        skos:notation "cumulative_capacity_ah" ;
                        skos:scopeNote "Suitable for throughput-based degradation models."@en ;
                        :latexSymbol "Q_\\mathrm{cum}"^^xsd:string ;
                        :latexFormula "Q_\\mathrm{cum}(t) = Q_\\mathrm{chg}(t) + Q_\\mathrm{dchg}(t) = \\frac{1}{3600}\\int_0^t \\bigl|I(\\tau)\\bigr|\\,\\mathrm{d}\\tau"^^xsd:string ;
                        :obligation "optional" ;
                        skos:prefLabel "Cumulative Capacity / Ah"@en ;
                        prov:wasDerivedFrom :current_ampere ,
                                            :test_time_second ;
                        schema:description "Total Ah throughput since test start: charging_capacity_ah + discharging_capacity_ah. Always monotonically non-decreasing."@en ;
                        schema:measurementTechnique "Running integral of the absolute value of current from test start (charge throughput). Always non-decreasing."@en ;
                        schema:name "Cumulative Capacity / Ah"@en ;
                        schema:unitCode "A.h" ;
                        schema:unitText "ampere hour"@en ;
                        emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Total Ah throughput since the start of the test, in ampere hour. Defined as charging_capacity_ah + discharging_capacity_ah; always monotonically non-decreasing. Counts charge flow in both directions and is therefore independent of the net state of charge."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cumulative_energy_wh
:cumulative_energy_wh rdf:type owl:Class ;
                      rdfs:subClassOf sosa:ObservableProperty ,
                                      electrochemistry:electrochemistry_0f986d97_445f_4075_a5ce_ddde598a47a9 ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                        owl:someValuesFrom emmo:WattHour
                                      ] ;
                      rdfs:comment "Total Wh throughput since the start of the test, in watt hour. Defined as charging_energy_wh + discharging_energy_wh; always monotonically non-decreasing."@en ;
                      rdfs:label "Cumulative Energy / Wh"@en ;
                      rdfs:seeAlso unit:W-HR ;
                      skos:altLabel "cumulative_energy_watt_hour"@en ,
                                    "cumulative_energy_wh"@en ;
                      skos:definition "Total Wh throughput since the start of the test, in watt hour. Defined as charging_energy_wh + discharging_energy_wh; always monotonically non-decreasing."@en ;
                      skos:exactMatch quantitykind:Energy ;
                      skos:notation "cumulative_energy_wh" ;
                      :latexSymbol "E_\\mathrm{cum}"^^xsd:string ;
                      :latexFormula "E_\\mathrm{cum}(t) = E_\\mathrm{chg}(t) + E_\\mathrm{dchg}(t) = \\frac{1}{3600}\\int_0^t P(\\tau)\\,\\operatorname{sgn} I(\\tau)\\,\\mathrm{d}\\tau"^^xsd:string ;
                      :obligation "optional" ;
                      skos:prefLabel "Cumulative Energy / Wh"@en ;
                      prov:wasDerivedFrom :power_watt ,
                                          :test_time_second ;
                      schema:description "Total Wh throughput since test start: charging_energy_wh + discharging_energy_wh. Always monotonically non-decreasing."@en ;
                      schema:measurementTechnique "Running integral of the absolute value of power from test start (energy throughput). Always non-decreasing."@en ;
                      schema:name "Cumulative Energy / Wh"@en ;
                      schema:unitCode "W.h" ;
                      schema:unitText "watt hour"@en ;
                      emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Total Wh throughput since the start of the test, in watt hour. Defined as charging_energy_wh + discharging_energy_wh; always monotonically non-decreasing."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#current_ampere
:current_ampere rdf:type owl:Class ;
                rdfs:subClassOf sosa:ObservableProperty ,
                                electrochemistry:electrochemistry_a24f8581_a5a4_41a4_bb45_d0fdd5c0d810 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                  owl:someValuesFrom emmo:Ampere
                                ] ;
                rdfs:comment "Instantaneous current flowing through the test object, in ampere. Sign convention: positive current charges the test object (current flows into it) and negative current discharges it; the charging and discharging capacity and energy quantities are defined by this convention."@en ;
                rdfs:label "Current / A"@en ;
                rdfs:seeAlso unit:A ;
                skos:altLabel "current_a"@en ,
                              "current_ampere"@en ;
                skos:definition "Instantaneous current flowing through the test object, in ampere. Sign convention: positive current charges the test object (current flows into it) and negative current discharges it; the charging and discharging capacity and energy quantities are defined by this convention."@en ;
                skos:exactMatch quantitykind:ElectricCurrent ;
                skos:notation "current_ampere" ;
                :latexSymbol "I"^^xsd:string ;
                :obligation "required" ;
                skos:prefLabel "Current / A"@en ;
                schema:description "Instantaneous current flowing through the test object, in ampere. Sign convention: positive current charges the test object (current flows into it) and negative current discharges it; the charging and discharging capacity and energy quantities are defined by this convention."@en ;
                schema:name "Current / A"@en ;
                schema:unitCode "A" ;
                schema:unitText "ampere"@en ;
                emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Instantaneous current flowing through the test object, in ampere. Sign convention: positive current charges the test object (current flows into it) and negative current discharges it; the charging and discharging capacity and energy quantities are defined by this convention."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_charging_capacity_ah
:cycle_charging_capacity_ah rdf:type owl:Class ;
                            rdfs:subClassOf sosa:ObservableProperty ,
                                            electrochemistry:10763eb0_dbc9_4d34_bd1a_7b8996590d45 ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                              owl:someValuesFrom emmo:AmpereHour
                                            ] ;
                            rdfs:comment "Electric charge transferred into the test object during the charge portions of the current cycle, in ampere hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of the positive part of current from the start of the current cycle. Equivalent to the cycle-level charge capacity reported by some instruments (e.g. Arbin Charge_Capacity in cycle-reset export configurations), which reset at each cycle boundary."@en ;
                            rdfs:label "Cycle Charging Capacity / Ah"@en ;
                            rdfs:seeAlso unit:A-HR ;
                            skos:altLabel "cycle_charge_capacity_ah"@en ,
                                          "cycle_charging_capacity_ah"@en ,
                                          "cycle_charging_capacity_ampere_hour"@en ;
                            skos:definition "Electric charge transferred into the test object during the charge portions of the current cycle, in ampere hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of the positive part of current from the start of the current cycle. Equivalent to the cycle-level charge capacity reported by some instruments (e.g. Arbin Charge_Capacity in cycle-reset export configurations), which reset at each cycle boundary."@en ;
                            skos:exactMatch quantitykind:ElectricCharge ;
                            skos:notation "cycle_charging_capacity_ah" ;
                            :latexSymbol "Q_\\mathrm{chg}^\\mathrm{cyc}"^^xsd:string ;
                            :latexFormula "Q_\\mathrm{chg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} \\max\\!\\bigl(I(\\tau),\\,0\\bigr)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
                            :obligation "optional" ;
                            skos:prefLabel "Cycle Charging Capacity / Ah"@en ;
                            prov:wasDerivedFrom :current_ampere ,
                                                :cycle_count ;
                            schema:description "Electric charge transferred into the test object during the charge portions of the current cycle, in ampere hour. Non-negative; resets to zero when cycle_count increments."@en ;
                            schema:measurementTechnique "Time integral of the positive part of current from the start of the current cycle."@en ;
                            schema:name "Cycle Charging Capacity / Ah"@en ;
                            schema:unitCode "A.h" ;
                            schema:unitText "ampere hour"@en ;
                            emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Electric charge transferred into the test object during the charge portions of the current cycle, in ampere hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of the positive part of current from the start of the current cycle. Equivalent to the cycle-level charge capacity reported by some instruments (e.g. Arbin Charge_Capacity in cycle-reset export configurations), which reset at each cycle boundary."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_charging_energy_wh
:cycle_charging_energy_wh rdf:type owl:Class ;
                          rdfs:subClassOf sosa:ObservableProperty ,
                                          electrochemistry:2ab7af60_da58_4243_b3bc_cbb2155cac53 ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                            owl:someValuesFrom emmo:WattHour
                                          ] ;
                          rdfs:comment "Energy transferred into the test object during the charge portions of the current cycle, in watt hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of instantaneous power over the charge intervals (current > 0) of the cycle. Equivalent to the cycle-level charge energy reported by some instruments (e.g. Arbin Charge_Energy in cycle-reset export configurations)."@en ;
                          rdfs:label "Cycle Charging Energy / Wh"@en ;
                          rdfs:seeAlso unit:W-HR ;
                          skos:altLabel "cycle_charge_energy_wh"@en ,
                                        "cycle_charging_energy_watt_hour"@en ,
                                        "cycle_charging_energy_wh"@en ;
                          skos:definition "Energy transferred into the test object during the charge portions of the current cycle, in watt hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of instantaneous power over the charge intervals (current > 0) of the cycle. Equivalent to the cycle-level charge energy reported by some instruments (e.g. Arbin Charge_Energy in cycle-reset export configurations)."@en ;
                          skos:exactMatch quantitykind:Energy ;
                          skos:notation "cycle_charging_energy_wh" ;
                          :latexSymbol "E_\\mathrm{chg}^\\mathrm{cyc}"^^xsd:string ;
                          :latexFormula "E_\\mathrm{chg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} P(\\tau)\\,\\bigl[I(\\tau) > 0\\bigr]\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle},\\quad [\\cdot] = \\text{1 if true, 0 otherwise}"^^xsd:string ;
                          :obligation "optional" ;
                          skos:prefLabel "Cycle Charging Energy / Wh"@en ;
                          prov:wasDerivedFrom :power_watt ,
                                              :cycle_count ;
                          schema:description "Energy transferred into the test object during the charge portions of the current cycle, in watt hour. Non-negative; resets to zero when cycle_count increments."@en ;
                          schema:measurementTechnique "Time integral of instantaneous power over the charge intervals (current > 0) of the current cycle."@en ;
                          schema:name "Cycle Charging Energy / Wh"@en ;
                          schema:unitCode "W.h" ;
                          schema:unitText "watt hour"@en ;
                          emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Energy transferred into the test object during the charge portions of the current cycle, in watt hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of instantaneous power over the charge intervals (current > 0) of the cycle. Equivalent to the cycle-level charge energy reported by some instruments (e.g. Arbin Charge_Energy in cycle-reset export configurations)."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_count
:cycle_count rdf:type owl:Class ;
             rdfs:subClassOf sosa:ObservableProperty ,
                             electrochemistry:electrochemistry_5766a819_c319_48ba_ab9a_ce3bd8fedee8 ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                               owl:someValuesFrom emmo:EMMO_5ebd5e01_0ed3_49a2_a30d_cd05cbe72978
                             ] ;
             rdfs:comment "Cycle index used to segregate time-series data into quasi-periodic subsets, typically tracking performance evolution over aging. Must be a non-negative integer and monotonically non-decreasing within a test. No constraint is placed on the starting value: 0, 1, or any other non-negative integer are all valid. The starting value is instrument-defined and must be preserved as reported; converters must not renumber cycles."@en ;
             rdfs:label "Cycle Count / 1"@en ;
             rdfs:seeAlso unit:NUM ;
             skos:altLabel "cycle_count"@en ,
                           "cycle_count_1"@en ,
                           "cycle_dimensionless"@en ;
             skos:definition "Cycle index used to segregate time-series data into quasi-periodic subsets, typically tracking performance evolution over aging. Must be a non-negative integer and monotonically non-decreasing within a test. No constraint is placed on the starting value: 0, 1, or any other non-negative integer are all valid. The starting value is instrument-defined and must be preserved as reported; converters must not renumber cycles."@en ;
             skos:exactMatch quantitykind:Count ;
             skos:notation "cycle_count" ;
             :latexSymbol "n"^^xsd:string ;
             :obligation "recommended" ;
             skos:prefLabel "Cycle Count / 1"@en ;
             schema:description "Cycle index, non-negative integer, monotonically non-decreasing within a test. Starting value is instrument-defined (any non-negative integer); converters must not renumber cycles."@en ;
             schema:name "Cycle Count / 1"@en ;
             schema:unitCode "1" ;
             schema:unitText "one"@en ;
             emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Cycle index used to segregate time-series data into quasi-periodic subsets, typically tracking performance evolution over aging. Must be a non-negative integer and monotonically non-decreasing within a test. No constraint is placed on the starting value: 0, 1, or any other non-negative integer are all valid. The starting value is instrument-defined and must be preserved as reported; converters must not renumber cycles."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_cumulative_capacity_ah
:cycle_cumulative_capacity_ah rdf:type owl:Class ;
                              rdfs:subClassOf sosa:ObservableProperty ,
                                              electrochemistry:ae108db7_8765_4329_9908_059277dee586 ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                                owl:someValuesFrom emmo:AmpereHour
                                              ] ;
                              rdfs:comment "Running accumulation of charge throughput within the current cycle, in ampere hour: the time integral of the absolute current from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_capacity_ah + cycle_discharging_capacity_ah."@en ;
                              rdfs:label "Cycle Cumulative Capacity / Ah"@en ;
                              rdfs:seeAlso unit:A-HR ;
                              skos:altLabel "cycle_cumulative_capacity_ah"@en ,
                                            "cycle_cumulative_capacity_ampere_hour"@en ;
                              skos:definition "Running accumulation of charge throughput within the current cycle, in ampere hour: the time integral of the absolute current from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_capacity_ah + cycle_discharging_capacity_ah."@en ;
                              skos:exactMatch quantitykind:ElectricCharge ;
                              skos:notation "cycle_cumulative_capacity_ah" ;
                              :latexSymbol "Q_\\mathrm{cum}^\\mathrm{cyc}"^^xsd:string ;
                              :latexFormula "Q_\\mathrm{cum}^\\mathrm{cyc}(t) = Q_\\mathrm{chg}^\\mathrm{cyc}(t) + Q_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} \\bigl|I(\\tau)\\bigr|\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
                              :obligation "optional" ;
                              skos:prefLabel "Cycle Cumulative Capacity / Ah"@en ;
                              prov:wasDerivedFrom :current_ampere ,
                                                  :cycle_count ;
                              schema:description "Running accumulation of charge throughput within the current cycle, in ampere hour. Monotonically non-decreasing within the cycle; resets to zero when cycle_count increments."@en ;
                              schema:measurementTechnique "Time integral of the absolute value of current from the start of the current cycle."@en ;
                              schema:name "Cycle Cumulative Capacity / Ah"@en ;
                              schema:unitCode "A.h" ;
                              schema:unitText "ampere hour"@en ;
                              emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Running accumulation of charge throughput within the current cycle, in ampere hour: the time integral of the absolute current from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_capacity_ah + cycle_discharging_capacity_ah."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_cumulative_energy_wh
:cycle_cumulative_energy_wh rdf:type owl:Class ;
                            rdfs:subClassOf sosa:ObservableProperty ,
                                            electrochemistry:46376e5d_9627_4514_9881_9e62083625c3 ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                              owl:someValuesFrom emmo:WattHour
                                            ] ;
                            rdfs:comment "Running accumulation of energy throughput within the current cycle, in watt hour: the time integral of the current-signed instantaneous power (P times the sign of I) from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_energy_wh + cycle_discharging_energy_wh."@en ;
                            rdfs:label "Cycle Cumulative Energy / Wh"@en ;
                            rdfs:seeAlso unit:W-HR ;
                            skos:altLabel "cycle_cumulative_energy_watt_hour"@en ,
                                          "cycle_cumulative_energy_wh"@en ;
                            skos:definition "Running accumulation of energy throughput within the current cycle, in watt hour: the time integral of the current-signed instantaneous power (P times the sign of I) from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_energy_wh + cycle_discharging_energy_wh."@en ;
                            skos:exactMatch quantitykind:Energy ;
                            skos:notation "cycle_cumulative_energy_wh" ;
                            :latexSymbol "E_\\mathrm{cum}^\\mathrm{cyc}"^^xsd:string ;
                            :latexFormula "E_\\mathrm{cum}^\\mathrm{cyc}(t) = E_\\mathrm{chg}^\\mathrm{cyc}(t) + E_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} P(\\tau)\\,\\operatorname{sgn} I(\\tau)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
                            :obligation "optional" ;
                            skos:prefLabel "Cycle Cumulative Energy / Wh"@en ;
                            prov:wasDerivedFrom :power_watt ,
                                                :cycle_count ;
                            schema:description "Running accumulation of energy throughput within the current cycle, in watt hour. Monotonically non-decreasing within the cycle; resets to zero when cycle_count increments."@en ;
                            schema:measurementTechnique "Time integral of the current-signed instantaneous power from the start of the current cycle."@en ;
                            schema:name "Cycle Cumulative Energy / Wh"@en ;
                            schema:unitCode "W.h" ;
                            schema:unitText "watt hour"@en ;
                            emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Running accumulation of energy throughput within the current cycle, in watt hour: the time integral of the current-signed instantaneous power (P times the sign of I) from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_energy_wh + cycle_discharging_energy_wh."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_discharging_capacity_ah
:cycle_discharging_capacity_ah rdf:type owl:Class ;
                               rdfs:subClassOf sosa:ObservableProperty ,
                                               electrochemistry:0141b5c2_9f15_46f4_82e6_92a104faa476 ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                                 owl:someValuesFrom emmo:AmpereHour
                                               ] ;
                               rdfs:comment "Electric charge transferred out of the test object during the discharge portions of the current cycle, in ampere hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of the negated negative part of current from the start of the current cycle. Equivalent to the cycle-level discharge capacity reported by some instruments (e.g. Arbin Discharge_Capacity in cycle-reset export configurations), which reset at each cycle boundary. Its end-of-cycle value is the discharge capacity of that cycle, the quantity conventionally plotted in capacity-fade curves."@en ;
                               rdfs:label "Cycle Discharging Capacity / Ah"@en ;
                               rdfs:seeAlso unit:A-HR ;
                               skos:altLabel "cycle_discharge_capacity_ah"@en ,
                                             "cycle_discharging_capacity_ah"@en ,
                                             "cycle_discharging_capacity_ampere_hour"@en ;
                               skos:definition "Electric charge transferred out of the test object during the discharge portions of the current cycle, in ampere hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of the negated negative part of current from the start of the current cycle. Equivalent to the cycle-level discharge capacity reported by some instruments (e.g. Arbin Discharge_Capacity in cycle-reset export configurations), which reset at each cycle boundary. Its end-of-cycle value is the discharge capacity of that cycle, the quantity conventionally plotted in capacity-fade curves."@en ;
                               skos:exactMatch quantitykind:ElectricCharge ;
                               skos:notation "cycle_discharging_capacity_ah" ;
                               :latexSymbol "Q_\\mathrm{dchg}^\\mathrm{cyc}"^^xsd:string ;
                               :latexFormula "Q_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} \\max\\!\\bigl(-I(\\tau),\\,0\\bigr)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
                               :obligation "optional" ;
                               skos:prefLabel "Cycle Discharging Capacity / Ah"@en ;
                               prov:wasDerivedFrom :current_ampere ,
                                                   :cycle_count ;
                               schema:description "Electric charge transferred out of the test object during the discharge portions of the current cycle, in ampere hour. Non-negative; resets to zero when cycle_count increments."@en ;
                               schema:measurementTechnique "Time integral of the negated negative part of current from the start of the current cycle."@en ;
                               schema:name "Cycle Discharging Capacity / Ah"@en ;
                               schema:unitCode "A.h" ;
                               schema:unitText "ampere hour"@en ;
                               emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Electric charge transferred out of the test object during the discharge portions of the current cycle, in ampere hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the time integral of the negated negative part of current from the start of the current cycle. Equivalent to the cycle-level discharge capacity reported by some instruments (e.g. Arbin Discharge_Capacity in cycle-reset export configurations), which reset at each cycle boundary. Its end-of-cycle value is the discharge capacity of that cycle, the quantity conventionally plotted in capacity-fade curves."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_discharging_energy_wh
:cycle_discharging_energy_wh rdf:type owl:Class ;
                             rdfs:subClassOf sosa:ObservableProperty ,
                                             electrochemistry:ca36cbf3_1fed_4b88_9177_b4e16ad00cf7 ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                               owl:someValuesFrom emmo:WattHour
                                             ] ;
                             rdfs:comment "Energy transferred out of the test object during the discharge portions of the current cycle, in watt hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the negated time integral of instantaneous power over the discharge intervals (current < 0) of the cycle. Equivalent to the cycle-level discharge energy reported by some instruments (e.g. Arbin Discharge_Energy in cycle-reset export configurations)."@en ;
                             rdfs:label "Cycle Discharging Energy / Wh"@en ;
                             rdfs:seeAlso unit:W-HR ;
                             skos:altLabel "cycle_discharge_energy_wh"@en ,
                                           "cycle_discharging_energy_watt_hour"@en ,
                                           "cycle_discharging_energy_wh"@en ;
                             skos:definition "Energy transferred out of the test object during the discharge portions of the current cycle, in watt hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the negated time integral of instantaneous power over the discharge intervals (current < 0) of the cycle. Equivalent to the cycle-level discharge energy reported by some instruments (e.g. Arbin Discharge_Energy in cycle-reset export configurations)."@en ;
                             skos:exactMatch quantitykind:Energy ;
                             skos:notation "cycle_discharging_energy_wh" ;
                             :latexSymbol "E_\\mathrm{dchg}^\\mathrm{cyc}"^^xsd:string ;
                             :latexFormula "E_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} -P(\\tau)\\,\\bigl[I(\\tau) < 0\\bigr]\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle},\\quad [\\cdot] = \\text{1 if true, 0 otherwise}"^^xsd:string ;
                             :obligation "optional" ;
                             skos:prefLabel "Cycle Discharging Energy / Wh"@en ;
                             prov:wasDerivedFrom :power_watt ,
                                                 :cycle_count ;
                             schema:description "Energy transferred out of the test object during the discharge portions of the current cycle, in watt hour. Non-negative; resets to zero when cycle_count increments."@en ;
                             schema:measurementTechnique "Negated time integral of instantaneous power over the discharge intervals (current < 0) of the current cycle."@en ;
                             schema:name "Cycle Discharging Energy / Wh"@en ;
                             schema:unitCode "W.h" ;
                             schema:unitText "watt hour"@en ;
                             emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Energy transferred out of the test object during the discharge portions of the current cycle, in watt hour. Non-negative (>= 0); resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Where computed, it is the negated time integral of instantaneous power over the discharge intervals (current < 0) of the cycle. Equivalent to the cycle-level discharge energy reported by some instruments (e.g. Arbin Discharge_Energy in cycle-reset export configurations)."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_net_capacity_ah
:cycle_net_capacity_ah rdf:type owl:Class ;
                       rdfs:subClassOf sosa:ObservableProperty ,
                                       electrochemistry:791c1915_a791_4450_acd8_7f94764743b5 ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                         owl:someValuesFrom emmo:AmpereHour
                                       ] ;
                       rdfs:comment "Net charge transferred during the current cycle, in ampere hour. Defined as cycle_charging_capacity_ah minus cycle_discharging_capacity_ah; the running signed integral of current from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more charge is extracted than injected during the cycle. Its end-of-cycle value is the per-cycle coulombic slippage: the irreversible charge consumed by side reactions during that cycle."@en ;
                       rdfs:label "Cycle Net Capacity / Ah"@en ;
                       rdfs:seeAlso unit:A-HR ;
                       skos:altLabel "cycle_net_capacity_ah"@en ,
                                     "cycle_net_capacity_ampere_hour"@en ;
                       skos:definition "Net charge transferred during the current cycle, in ampere hour. Defined as cycle_charging_capacity_ah minus cycle_discharging_capacity_ah; the running signed integral of current from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more charge is extracted than injected during the cycle. Its end-of-cycle value is the per-cycle coulombic slippage: the irreversible charge consumed by side reactions during that cycle."@en ;
                       skos:exactMatch quantitykind:ElectricCharge ;
                       skos:notation "cycle_net_capacity_ah" ;
                       :latexSymbol "Q_\\mathrm{net}^\\mathrm{cyc}"^^xsd:string ;
                       :latexFormula "Q_\\mathrm{net}^\\mathrm{cyc}(t) = Q_\\mathrm{chg}^\\mathrm{cyc}(t) - Q_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} I(\\tau)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
                       :obligation "optional" ;
                       skos:prefLabel "Cycle Net Capacity / Ah"@en ;
                       prov:wasDerivedFrom :cycle_charging_capacity_ah ,
                                           :cycle_discharging_capacity_ah ;
                       schema:description "Running net capacity within the current cycle: cycle_charging_capacity_ah - cycle_discharging_capacity_ah. Can be negative; resets to zero when cycle_count increments."@en ;
                       schema:measurementTechnique "Running signed integral of current from the start of the current cycle."@en ;
                       schema:name "Cycle Net Capacity / Ah"@en ;
                       schema:unitCode "A.h" ;
                       schema:unitText "ampere hour"@en ;
                       emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Net charge transferred during the current cycle, in ampere hour. Defined as cycle_charging_capacity_ah minus cycle_discharging_capacity_ah; the running signed integral of current from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more charge is extracted than injected during the cycle. Its end-of-cycle value is the per-cycle coulombic slippage: the irreversible charge consumed by side reactions during that cycle."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#cycle_net_energy_wh
:cycle_net_energy_wh rdf:type owl:Class ;
                     rdfs:subClassOf sosa:ObservableProperty ,
                                     electrochemistry:46376e5d_9627_4514_9881_9e62083625c3 ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                       owl:someValuesFrom emmo:WattHour
                                     ] ;
                     rdfs:comment "Net energy transferred during the current cycle, in watt hour. Defined as cycle_charging_energy_wh minus cycle_discharging_energy_wh; the running signed integral of instantaneous power from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more energy is extracted than delivered during the cycle. Its end-of-cycle value is the net energy absorbed over that cycle, reflecting voltage hysteresis and other losses."@en ;
                     rdfs:label "Cycle Net Energy / Wh"@en ;
                     rdfs:seeAlso unit:W-HR ;
                     skos:altLabel "cycle_net_energy_watt_hour"@en ,
                                   "cycle_net_energy_wh"@en ;
                     skos:definition "Net energy transferred during the current cycle, in watt hour. Defined as cycle_charging_energy_wh minus cycle_discharging_energy_wh; the running signed integral of instantaneous power from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more energy is extracted than delivered during the cycle. Its end-of-cycle value is the net energy absorbed over that cycle, reflecting voltage hysteresis and other losses."@en ;
                     skos:exactMatch quantitykind:Energy ;
                     skos:notation "cycle_net_energy_wh" ;
                     :latexSymbol "E_\\mathrm{net}^\\mathrm{cyc}"^^xsd:string ;
                     :latexFormula "E_\\mathrm{net}^\\mathrm{cyc}(t) = E_\\mathrm{chg}^\\mathrm{cyc}(t) - E_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} P(\\tau)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
                     :obligation "optional" ;
                     skos:prefLabel "Cycle Net Energy / Wh"@en ;
                     prov:wasDerivedFrom :cycle_charging_energy_wh ,
                                         :cycle_discharging_energy_wh ;
                     schema:description "Running net energy within the current cycle: cycle_charging_energy_wh - cycle_discharging_energy_wh. Can be negative; resets to zero when cycle_count increments."@en ;
                     schema:measurementTechnique "Running signed integral of instantaneous power from the start of the current cycle."@en ;
                     schema:name "Cycle Net Energy / Wh"@en ;
                     schema:unitCode "W.h" ;
                     schema:unitText "watt hour"@en ;
                     emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Net energy transferred during the current cycle, in watt hour. Defined as cycle_charging_energy_wh minus cycle_discharging_energy_wh; the running signed integral of instantaneous power from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more energy is extracted than delivered during the cycle. Its end-of-cycle value is the net energy absorbed over that cycle, reflecting voltage hysteresis and other losses."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#dc_internal_resistance_ohm
:dc_internal_resistance_ohm rdf:type owl:Class ;
                            rdfs:subClassOf sosa:ObservableProperty ,
                                            :internal_resistance_ohm ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                              owl:someValuesFrom emmo:Ohm
                                            ] ;
                            rdfs:comment "Direct current internal resistance of the test object, in ohm, determined from the voltage response to a current step (e.g. delta-V over delta-I across a current pulse). The method parameters (pulse magnitude and duration) are instrument-specific and not standardised; values obtained with different methods are not directly comparable."@en ;
                            rdfs:label "DC Internal Resistance / ohm"@en ;
                            rdfs:seeAlso unit:OHM ;
                            skos:altLabel "dc_internal_resistance_ohm"@en ,
                                          "dc_resistance_ohm"@en ,
                                          "dcir"@en ;
                            skos:definition "Direct current internal resistance of the test object, in ohm, determined from the voltage response to a current step (e.g. delta-V over delta-I across a current pulse). The method parameters (pulse magnitude and duration) are instrument-specific and not standardised; values obtained with different methods are not directly comparable."@en ;
                            skos:exactMatch quantitykind:Resistance ;
                            skos:notation "dc_internal_resistance_ohm" ;
                            :latexSymbol "R_\\mathrm{DC}"^^xsd:string ;
                            :obligation "optional" ;
                            skos:prefLabel "DC Internal Resistance / ohm"@en ;
                            schema:description "DC internal resistance from the voltage response to a current step. Method parameters are instrument-specific; values from different methods are not directly comparable."@en ;
                            schema:name "DC Internal Resistance / ohm"@en ;
                            schema:unitCode "Ohm" ;
                            schema:unitText "ohm"@en ;
                            emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Direct current internal resistance of the test object, in ohm, determined from the voltage response to a current step (e.g. delta-V over delta-I across a current pulse). The method parameters (pulse magnitude and duration) are instrument-specific and not standardised; values obtained with different methods are not directly comparable."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#discharging_capacity_ah
:discharging_capacity_ah rdf:type owl:Class ;
                         rdfs:subClassOf sosa:ObservableProperty ,
                                         electrochemistry:electrochemistry_0141b5c2_9f15_46f4_82e6_92a104faa476 ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                           owl:someValuesFrom emmo:AmpereHour
                                         ] ;
                         rdfs:comment "Cumulative electric charge transferred out of the test object during discharging, in ampere hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during discharge intervals; unchanged during rest or charge. Note: differs from step-level Q discharge as reported by some instruments (e.g. BioLogic EC-Lab), which reset to zero at each step boundary."@en ;
                         rdfs:label "Discharging Capacity / Ah"@en ;
                         rdfs:seeAlso unit:A-HR ;
                         skos:altLabel "discharging_capacity_ah"@en ,
                                       "discharging_capacity_ampere_hour"@en ;
                         skos:definition "Cumulative electric charge transferred out of the test object during discharging, in ampere hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during discharge intervals; unchanged during rest or charge. Note: differs from step-level Q discharge as reported by some instruments (e.g. BioLogic EC-Lab), which reset to zero at each step boundary."@en ;
                         skos:exactMatch quantitykind:ElectricCharge ;
                         skos:notation "discharging_capacity_ah" ;
                         :latexSymbol "Q_\\mathrm{dchg}"^^xsd:string ;
                         :latexFormula "Q_\\mathrm{dchg}(t) = \\frac{1}{3600}\\int_0^t \\max\\!\\bigl(-I(\\tau),\\,0\\bigr)\\,\\mathrm{d}\\tau"^^xsd:string ;
                         :obligation "optional" ;
                         skos:prefLabel "Discharging Capacity / Ah"@en ;
                         prov:wasDerivedFrom :current_ampere ,
                                             :test_time_second ;
                         schema:description "Cumulative electric charge transferred out of the test object during discharging since test start, in ampere hour. Never resets between steps or cycles."@en ;
                         schema:name "Discharging Capacity / Ah"@en ;
                         schema:unitCode "A.h" ;
                         schema:unitText "ampere hour"@en ;
                         emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Cumulative electric charge transferred out of the test object during discharging, in ampere hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during discharge intervals; unchanged during rest or charge. Note: differs from step-level Q discharge as reported by some instruments (e.g. BioLogic EC-Lab), which reset to zero at each step boundary."@en .


###  https://w3id.org/battery-data-alliance/ontology/battery-data-format#discharging_energy_wh
:discharging_energy_wh rdf:type owl:Class ;
                       rdfs:subClassOf sosa:ObservableProperty ,
                                       electrochemistry:electrochemistry_ca36cbf3_1fed_4b88_9177_b4e16ad00cf7 ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
                                         owl:someValuesFrom emmo:WattHour
                                       ] ;
                       rdfs:comment "Cumulative energy transferred out of the test object during discharging, in watt hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during discharge intervals; unchanged during rest or charge."@en ;
                       rdfs:label "Discharging Energy / Wh"@en ;
                       rdfs:seeAlso unit:W-HR ;
                       skos:altLabel "discharging_energy_watt_hour"@en ,
                                     "discharging_energy_wh"@en ;
                       skos:definition "Cumulative energy transferred out of the test object during discharging, in watt hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during discharge intervals; unchanged during rest or charge."@en ;
                       skos:exactMatch quantitykind:Energy ;
                       skos:notation "discharging_energy_wh" ;
                       :latexSymbol "E_\\mathrm{dchg}"^^xsd:string ;
                       :latexFormula "E_\\mathrm{dchg}(t) = \\frac{1}{3600}\\int_0^t -P(\\tau)\\,\\bigl[I(\\tau) < 0\\bigr]\\,\\mathrm{d}\\tau,\\quad [\\cdot] = \\text{1 if true, 0 otherwise}"^^xsd:string ;
                       :obligation "optional" ;
                       skos:prefLabel "Discharging Energy / Wh"@en ;
                       prov:wasDerivedFrom :power_watt ,
                                           :test_time_second ;
                       schema:description "Cumulative energy transferred out of the test object during discharging since test start, in watt hour. Never resets between steps or cycles."@en ;
                       schema:name "Discharging Energy / Wh"@en ;
                       schema:unitCode "W.h" ;
                       schema:unitText "watt hour"@en ;
                       emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Cumulative energy transferred out of the test object during discharging, in watt hour. Accumulates from the start of the test and never resets between steps or cycles. Increases only during discharge intervals; unchanged during rest or charge."@en .


