###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#amplitude
arbin:amplitude rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Amplitude"@en ;
     skos:prefLabel "Amplitude"@en ;
     skos:altLabel "Amplitude" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:verificationStatus "unverified" ;
     skos:scopeNote "Not observed in sampled exports; unit mode-dependent (ampere galvanostatic vs volt potentiostatic). Retained from the documented header inventory."@en ;
     skos:definition "AC excitation amplitude reported on the channel time-series (documented for .res/SQL exports). UNVERIFIED: not present in any sampled CSV/XLSX file, and its unit (ampere vs volt) depends on the drive mode; no unit is asserted. By analogy with the EIS sheet it is expected to be an RMS current under galvanostatic drive."@en ;
     rdfs:comment "AC excitation amplitude reported on the channel time-series (documented for .res/SQL exports). UNVERIFIED: not present in any sampled CSV/XLSX file, and its unit (ampere vs volt) depends on the drive mode; no unit is asserted. By analogy with the EIS sheet it is expected to be an RMS current under galvanostatic drive."@en .

