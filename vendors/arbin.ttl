     schema:unitCode "degC/s" ;
     schema:unitText "degree Celsius per second"@en ;
     skos:definition "Time derivative of an auxiliary temperature channel, in degree Celsius per second (Aux_dT/dt_N). Vendor-only; indexed."@en ;
     rdfs:comment "Time derivative of an auxiliary temperature channel, in degree Celsius per second (Aux_dT/dt_N). Vendor-only; indexed."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#aux_voltage_volt
arbin:aux_voltage_volt rdf:type owl:Class ;
