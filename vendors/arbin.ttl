     rdfs:comment "Imaginary part Z'' of the complex impedance, in ohm. Maps to bdf:imaginary_impedance_ohm."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#ocv_volt
arbin:ocv_volt rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Open-circuit Voltage (EIS)"@en ;
     skos:prefLabel "Open-circuit Voltage (EIS)"@en ;
     skos:altLabel "OCV" ;
     arbin:role "measurement" ;
     arbin:sheetScope "eis" ;
     schema:unitCode "V" ;
     schema:unitText "volt"@en ;
     skos:definition "Open-circuit (rest) voltage recorded on the EIS sheet, in volt. Vendor-only: no BDF core open-circuit-voltage term exists."@en ;
     rdfs:comment "Open-circuit (rest) voltage recorded on the EIS sheet, in volt. Vendor-only: no BDF core open-circuit-voltage term exists."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#ac_amplitude_rms
arbin:ac_amplitude_rms rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "AC Amplitude (RMS)"@en ;
     skos:prefLabel "AC Amplitude (RMS)"@en ;
     skos:altLabel "AC_Amp_RMS" ;
     arbin:role "measurement" ;
     arbin:sheetScope "eis" ;
     skos:scopeNote "Verified galvanostatic (Driven_Type='Galvanostatic') in all accessible EIS data -> RMS current in ampere. The potentiostatic->volt branch is a documented-convention inference, not observed."@en ;
     skos:definition "RMS amplitude of the AC excitation on the EIS sheet. The unit is keyed by arbin:driven_type: in the galvanostatic mode observed across all available EIS sheets it is an RMS current in ampere; a potentiostatic sheet would express it as a voltage in volt. No fixed unit is asserted because it is mode-dependent."@en ;
     rdfs:comment "RMS amplitude of the AC excitation on the EIS sheet. The unit is keyed by arbin:driven_type: in the galvanostatic mode observed across all available EIS sheets it is an RMS current in ampere; a potentiostatic sheet would express it as a voltage in volt. No fixed unit is asserted because it is mode-dependent."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#dc_base
arbin:dc_base rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "DC Base Level"@en ;
     skos:prefLabel "DC Base Level"@en ;
     skos:altLabel "DC_Base" ;
     arbin:role "measurement" ;
     arbin:sheetScope "eis" ;
     skos:scopeNote "Verified galvanostatic -> DC current in ampere, observed constant 0 (measured at OCV). The potentiostatic->volt branch is a documented-convention inference, not observed."@en ;
     skos:definition "DC bias about which the AC excitation is applied on the EIS sheet. The unit is keyed by arbin:driven_type: in the observed galvanostatic mode it is a DC current in ampere (a value of 0 indicating measurement at open-circuit with no DC offset); a potentiostatic sheet would express it as a voltage in volt."@en ;
     rdfs:comment "DC bias about which the AC excitation is applied on the EIS sheet. The unit is keyed by arbin:driven_type: in the observed galvanostatic mode it is a DC current in ampere (a value of 0 indicating measurement at open-circuit with no DC offset); a potentiostatic sheet would express it as a voltage in volt."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#driven_type
arbin:driven_type rdf:type owl:Class ;
     rdfs:label "EIS Drive Mode"@en ;
     skos:prefLabel "EIS Drive Mode"@en ;
     skos:altLabel "Driven_Type" ;
     arbin:role "metadata" ;
     arbin:sheetScope "eis" ;
     skos:definition "EIS excitation control mode, e.g. 'Galvanostatic' or 'Potentiostatic'; determines the units of AC_Amp_RMS and DC_Base. Vendor metadata."@en ;
     rdfs:comment "EIS excitation control mode, e.g. 'Galvanostatic' or 'Potentiostatic'; determines the units of AC_Amp_RMS and DC_Base. Vendor metadata."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#eis_product_id
arbin:eis_product_id rdf:type owl:Class ;
     rdfs:label "EIS Instrument Product Identifier"@en ;
     skos:prefLabel "EIS Instrument Product Identifier"@en ;
     skos:altLabel "Product_ID" ;
     arbin:role "identifier" ;
     arbin:sheetScope "eis" ;
     skos:definition "Identifier of the impedance instrument that produced the EIS sheet (e.g. 'Gamry_1'). Vendor-only nominal identifier."@en ;
     rdfs:comment "Identifier of the impedance instrument that produced the EIS sheet (e.g. 'Gamry_1'). Vendor-only nominal identifier."@en .

