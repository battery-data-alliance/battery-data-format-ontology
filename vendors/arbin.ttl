arbin:metacode_mv_ud rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "User-defined Meta Variable"@en ;
     skos:prefLabel "User-defined Meta Variable"@en ;
     skos:altLabel "MetaCode_MV_UD1" ;
     skos:altLabel "MetaCode_MV_UD2" ;
     skos:altLabel "MetaCode_MV_UD3" ;
     skos:altLabel "MetaCode_MV_UD4" ;
     skos:altLabel "MetaCode_MV_UD5" ;
     skos:altLabel "MetaCode_MV_UD6" ;
     skos:altLabel "MetaCode_MV_UD7" ;
     skos:altLabel "MetaCode_MV_UD8" ;
     skos:altLabel "MetaCode_MV_UD16" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:headerPattern "^MetaCode_MV_UD\\d+$" ;
     skos:definition "User-defined CAN/meta variables written by the schedule (MetaCode_MV_UD1..UD8 and UD16); values are test-program-defined and carry no fixed physical meaning. Vendor-only; indexed."@en ;
     rdfs:comment "User-defined CAN/meta variables written by the schedule (MetaCode_MV_UD1..UD8 and UD16); values are test-program-defined and carry no fixed physical meaning. Vendor-only; indexed."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#aux_temperature_celsius
arbin:aux_temperature_celsius rdf:type owl:Class ;
     rdfs:subClassOf bdf:temperature_t1_celsius ;
     skos:exactMatch bdf:temperature_t1_celsius ;
     rdfs:label "Auxiliary Temperature Channel"@en ;
     skos:prefLabel "Auxiliary Temperature Channel"@en ;
     skos:altLabel "Aux_Temperature_1(C)" ;
     skos:altLabel "Aux_Temperature_1 (C)" ;
     skos:altLabel "Aux_Temperature_2(C)" ;
     skos:altLabel "Aux_Temperature_2 (C)" ;
     skos:altLabel "Aux_Temperature_3 (C)" ;
     skos:altLabel "Aux_Temperature(C)" ;
     skos:altLabel "Temperature" ;
     skos:altLabel "Temperature(C)" ;
     skos:altLabel "Temperature (C)" ;
     skos:altLabel "Aux_Temperature(¡æ)_1" ;
     skos:altLabel "Aux_Temperature(¡æ)_2" ;
     skos:altLabel "Aux_Temperature(¡æ)_3" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     arbin:headerPattern "^Aux_Temperature(_\\d+ ?\\(C\\)|\\(¡æ\\)_\\d+|\\(C\\))$" ;
     schema:unitCode "degC" ;
     schema:unitText "degree Celsius"@en ;
     skos:scopeNote "Aux_Temperature_N maps channel-for-channel to bdf:temperature_tN_celsius; the exactMatch names the representative t1 channel term per the BDF numbered-channel convention."@en ;
     skos:definition "Auxiliary thermocouple temperature reading, in degree Celsius, on an indexed channel (Aux_Temperature_N). Channel index N corresponds to BDF temperature_tN_celsius; mapped here to the representative core channel term. Indexed; also seen as a bare 'Temperature' column and, under a GBK code-page mojibake, as 'Aux_Temperature(¡æ)_N'."@en ;
     rdfs:comment "Auxiliary thermocouple temperature reading, in degree Celsius, on an indexed channel (Aux_Temperature_N). Channel index N corresponds to BDF temperature_tN_celsius; mapped here to the representative core channel term. Indexed; also seen as a bare 'Temperature' column and, under a GBK code-page mojibake, as 'Aux_Temperature(¡æ)_N'."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#aux_dt_dt
arbin:aux_dt_dt rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Auxiliary Temperature Time Derivative"@en ;
     skos:prefLabel "Auxiliary Temperature Time Derivative"@en ;
     skos:altLabel "Aux_dT/dt_1 (C/s)" ;
     skos:altLabel "Aux_dT/dt_1(C/s)" ;
     skos:altLabel "Aux_dT/dt_2 (C/s)" ;
     skos:altLabel "Aux_dT/dt_3 (C/s)" ;
