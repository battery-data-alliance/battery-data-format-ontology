###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#tc_counter
arbin:tc_counter rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Schedule Loop Counter (TC_Counter)"@en ;
     skos:prefLabel "Schedule Loop Counter (TC_Counter)"@en ;
     skos:altLabel "TC_Counter1" ;
     skos:altLabel "TC_Counter2" ;
     skos:altLabel "TC_Counter3" ;
     skos:altLabel "TC_Counter4" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     arbin:headerPattern "^TC_Counter\\d+$" ;
     skos:scopeNote "Verified: TC_Counter1 moves in lock-step with Cycle Index (outer loop) and TC_Counter2 resets 11->0 per cycle (inner loop). They do NOT by themselves expose the accumulator reset boundaries: none of the observed Charge/Discharge_Capacity resets coincide with a TC_Counter change; those resets align with Step_Index transitions instead."@en ;
     skos:definition "Nested schedule loop-iteration counters exposed by the test-control engine (TC_Counter1..TC_Counter4), where TC_Counter1 is the outermost loop and higher indices are inner loops; unused inner levels stay zero. Non-negative integers. Vendor-only; indexed 1..4."@en ;
     rdfs:comment "Nested schedule loop-iteration counters exposed by the test-control engine (TC_Counter1..TC_Counter4), where TC_Counter1 is the outermost loop and higher indices are inner loops; unused inner levels stay zero. Non-negative integers. Vendor-only; indexed 1..4."@en .

