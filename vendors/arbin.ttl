@prefix arbin: <https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#> .
@prefix bdf: <https://w3id.org/battery-data-alliance/ontology/battery-data-format#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin> rdf:type owl:Ontology ;
     owl:imports <https://w3id.org/battery-data-alliance/ontology/battery-data-format> ;
     dcterms:title "Arbin Vendor Ontology Module for the Battery Data Format"@en ;
     dcterms:description "A vendor crosswalk ontology that resolves every native column or field exported by Arbin Battery Test System cyclers (channel time-series, EIS ACIM sheets, statistics sheets, and Global_Info metadata; MITS/MITS_PRO/DataPro CSV and XLSX, .res, SQL and h5 backends) to honest semantics. One class per concept; every dialect spelling is a verbatim skos:altLabel. Concepts with a BDF core equivalent carry rdfs:subClassOf and skos:exactMatch to the core IRI; the remainder are vendor-only, self-described terms."@en ;
     dcterms:creator <https://orcid.org/0000-0002-8758-6109> ;
     dcterms:publisher "Battery Data Alliance" ;
     dcterms:license <http://www.apache.org/licenses/LICENSE-2.0> ;
     rdfs:seeAlso <https://w3id.org/battery-data-alliance/ontology/battery-data-format/schema/vendors/arbin> .


#################################################################
#    Annotation properties
#################################################################

arbin:role rdf:type owl:AnnotationProperty ;
     rdfs:comment "Functional role of the column/field: measurement, derived, identifier, bookkeeping, or metadata."@en ;
     rdfs:isDefinedBy <https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin> .

arbin:sheetScope rdf:type owl:AnnotationProperty ;
     rdfs:comment "Export sheet/context in which the header appears: timeseries, eis, statistics, or metadata."@en ;
     rdfs:isDefinedBy <https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin> .

arbin:headerPattern rdf:type owl:AnnotationProperty ;
     rdfs:comment "Regular expression matching the indexed native header spellings of an indexed term family."@en ;
     rdfs:isDefinedBy <https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin> .

arbin:verificationStatus rdf:type owl:AnnotationProperty ;
     rdfs:comment "Set to 'unverified' when the term's semantics or unit have not yet been confirmed against real exports; such terms carry no core mapping."@en ;
     rdfs:isDefinedBy <https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin> .


#################################################################
#    Tier 1 — channel time-series
#################################################################

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#record_index
arbin:record_index rdf:type owl:Class ;
     rdfs:subClassOf bdf:record_index ;
     skos:exactMatch bdf:record_index ;
     rdfs:label "Record Index"@en ;
     skos:prefLabel "Record Index"@en ;
     skos:altLabel "Data_Point" ;
     skos:altLabel "Data Point" ;
     skos:altLabel "data_point" ;
     arbin:role "identifier" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     skos:definition "Ordinal one-based counter incremented by one per recorded row within a channel time-series, ordering records but carrying no physical meaning. Absent from some MITS_PRO/DataPro exports (e.g. lithiumwerks, mushang)."@en ;
     rdfs:comment "Ordinal one-based counter incremented by one per recorded row within a channel time-series, ordering records but carrying no physical meaning. Absent from some MITS_PRO/DataPro exports (e.g. lithiumwerks, mushang)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#date_time
arbin:date_time rdf:type owl:Class ;
     rdfs:subClassOf bdf:unix_time_second ;
     skos:exactMatch bdf:unix_time_second ;
     rdfs:label "Wall-clock Timestamp"@en ;
     skos:prefLabel "Wall-clock Timestamp"@en ;
     skos:altLabel "Date_Time" ;
     skos:altLabel "Date Time" ;
     skos:altLabel "DateTime" ;
     skos:altLabel "Date_Time                    " ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     skos:definition "Absolute wall-clock timestamp of the record. Encoded differently across Arbin exports: datetime strings in at least three formats (CSV/xlsx), an Excel serial number in .res exports, and 100-nanosecond epoch ticks in the SQL backend. In space-dialect CSV the value may carry a leading tab; in statistics sheets the header is right-padded with spaces. Normalises to bdf:unix_time_second (Unix epoch seconds)."@en ;
     rdfs:comment "Absolute wall-clock timestamp of the record. Encoded differently across Arbin exports: datetime strings in at least three formats (CSV/xlsx), an Excel serial number in .res exports, and 100-nanosecond epoch ticks in the SQL backend. In space-dialect CSV the value may carry a leading tab; in statistics sheets the header is right-padded with spaces. Normalises to bdf:unix_time_second (Unix epoch seconds)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#test_time_second
arbin:test_time_second rdf:type owl:Class ;
     rdfs:subClassOf bdf:test_time_second ;
     skos:exactMatch bdf:test_time_second ;
     rdfs:label "Test Time"@en ;
     skos:prefLabel "Test Time"@en ;
     skos:altLabel "Test Time (s)" ;
     skos:altLabel "Test_Time(s)" ;
     skos:altLabel "Test Time(s)" ;
     skos:altLabel "Test_Time" ;
     skos:altLabel "TestTime(s)" ;
     skos:altLabel "test_time_s" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     arbin:sheetScope "eis" ;
     schema:unitCode "s" ;
     schema:unitText "second"@en ;
     skos:definition "Elapsed time since the start of the test schedule, in seconds; monotonic across the whole test and never reset. Instrument-reported."@en ;
     rdfs:comment "Elapsed time since the start of the test schedule, in seconds; monotonic across the whole test and never reset. Instrument-reported."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#step_time_second
arbin:step_time_second rdf:type owl:Class ;
     rdfs:subClassOf bdf:step_time_second ;
     skos:exactMatch bdf:step_time_second ;
     rdfs:label "Step Time"@en ;
     skos:prefLabel "Step Time"@en ;
     skos:altLabel "Step Time (s)" ;
     skos:altLabel "Step_Time(s)" ;
     skos:altLabel "Step Time(s)" ;
     skos:altLabel "Step_Time" ;
     skos:altLabel "StepTime(s)" ;
     skos:altLabel "step_time_s" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "s" ;
     schema:unitText "second"@en ;
     skos:definition "Elapsed time since the start of the current schedule step, in seconds; resets to zero at each step transition. Instrument-reported. MITS 7 long-format code PV3 (PV_Steptime)."@en ;
     rdfs:comment "Elapsed time since the start of the current schedule step, in seconds; resets to zero at each step transition. Instrument-reported. MITS 7 long-format code PV3 (PV_Steptime)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#cycle_index
arbin:cycle_index rdf:type owl:Class ;
     rdfs:subClassOf bdf:cycle_count ;
     skos:exactMatch bdf:cycle_count ;
     rdfs:label "Cycle Index"@en ;
     skos:prefLabel "Cycle Index"@en ;
     skos:altLabel "Cycle Index" ;
     skos:altLabel "Cycle_Index" ;
     skos:altLabel "Cycle_ID" ;
     skos:altLabel "cycle_index" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     arbin:sheetScope "eis" ;
     skos:scopeNote "Schedule-authored counter: the value at which it increments is defined by the test program, not derivable from the current/voltage time-series alone."@en ;
     skos:definition "Cycle counter assigned by the instrument. The increment rule is authored in the test schedule (it advances on a schedule-defined cycle boundary, not necessarily one charge/discharge pair), so it is a program-defined counter rather than a data-derived one. MITS 7 code PV2 (PV_CycleIndex)."@en ;
     rdfs:comment "Cycle counter assigned by the instrument. The increment rule is authored in the test schedule (it advances on a schedule-defined cycle boundary, not necessarily one charge/discharge pair), so it is a program-defined counter rather than a data-derived one. MITS 7 code PV2 (PV_CycleIndex)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#step_index
arbin:step_index rdf:type owl:Class ;
     rdfs:subClassOf bdf:step_id ;
     skos:exactMatch bdf:step_id ;
     rdfs:label "Step Index"@en ;
     skos:prefLabel "Step Index"@en ;
     skos:altLabel "Step Index" ;
     skos:altLabel "Step_Index" ;
     skos:altLabel "Step_ID" ;
     skos:altLabel "step_index" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     arbin:sheetScope "eis" ;
     skos:definition "Ordinal identifier of the currently executing schedule step. Nominal (not a measured quantity). MITS 7 code PV1 (PV_StepIndex)."@en ;
     rdfs:comment "Ordinal identifier of the currently executing schedule step. Nominal (not a measured quantity). MITS 7 code PV1 (PV_StepIndex)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#sub_step_index
arbin:sub_step_index rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Sub-step Index"@en ;
     skos:prefLabel "Sub-step Index"@en ;
     skos:altLabel "Sub_Step_Index" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     skos:definition "Ordinal identifier of a sub-step within the current schedule step; Arbin-specific finer-grained control-flow index with no BDF core equivalent."@en ;
     rdfs:comment "Ordinal identifier of a sub-step within the current schedule step; Arbin-specific finer-grained control-flow index with no BDF core equivalent."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#sub_step_time_second
arbin:sub_step_time_second rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Sub-step Time"@en ;
     skos:prefLabel "Sub-step Time"@en ;
     skos:altLabel "Sub_Step_Time" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     schema:unitCode "s" ;
     schema:unitText "second"@en ;
     skos:definition "Elapsed time within the current sub-step, in seconds. Arbin-specific; no BDF core equivalent."@en ;
     rdfs:comment "Elapsed time within the current sub-step, in seconds. Arbin-specific; no BDF core equivalent."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#current_ampere
arbin:current_ampere rdf:type owl:Class ;
     rdfs:subClassOf bdf:current_ampere ;
     skos:exactMatch bdf:current_ampere ;
     rdfs:label "Current"@en ;
     skos:prefLabel "Current"@en ;
     skos:altLabel "Current (A)" ;
     skos:altLabel "Current(A)" ;
     skos:altLabel "Current" ;
     skos:altLabel "Current_A" ;
     skos:altLabel "current_a" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "A" ;
     schema:unitText "ampere"@en ;
     skos:definition "Instantaneous cell current, in ampere. Signed with the Arbin convention that positive current is charge. MITS 7 code PV22 (PV_Current)."@en ;
     rdfs:comment "Instantaneous cell current, in ampere. Signed with the Arbin convention that positive current is charge. MITS 7 code PV22 (PV_Current)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#voltage_volt
arbin:voltage_volt rdf:type owl:Class ;
     rdfs:subClassOf bdf:voltage_volt ;
     skos:exactMatch bdf:voltage_volt ;
     rdfs:label "Voltage"@en ;
     skos:prefLabel "Voltage"@en ;
     skos:altLabel "Voltage (V)" ;
     skos:altLabel "Voltage(V)" ;
     skos:altLabel "Voltage" ;
     skos:altLabel "Voltage_V" ;
     skos:altLabel "voltage_v" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "V" ;
     schema:unitText "volt"@en ;
     skos:definition "Instantaneous cell terminal voltage, in volt. MITS 7 code PV21 (PV_Voltage)."@en ;
     rdfs:comment "Instantaneous cell terminal voltage, in volt. MITS 7 code PV21 (PV_Voltage)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#power_watt
arbin:power_watt rdf:type owl:Class ;
     rdfs:subClassOf bdf:power_watt ;
     skos:exactMatch bdf:power_watt ;
     rdfs:label "Power"@en ;
     skos:prefLabel "Power"@en ;
     skos:altLabel "Power (W)" ;
     skos:altLabel "Power(W)" ;
     skos:altLabel "Power" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "W" ;
     schema:unitText "watt"@en ;
     skos:definition "Instantaneous electrical power, in watt; product of current and voltage."@en ;
     rdfs:comment "Instantaneous electrical power, in watt; product of current and voltage."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#charging_capacity_ah
arbin:charging_capacity_ah rdf:type owl:Class ;
     rdfs:subClassOf bdf:schedule_charging_capacity_ah ;
     skos:exactMatch bdf:schedule_charging_capacity_ah ;
     rdfs:label "Charge Capacity"@en ;
     skos:prefLabel "Charge Capacity"@en ;
     skos:altLabel "Charge Capacity (Ah)" ;
     skos:altLabel "Charge_Capacity(Ah)" ;
     skos:altLabel "Charge Capacity(Ah)" ;
     skos:altLabel "Charge_Capacity" ;
     skos:altLabel "Chg_Capacity(Ah)" ;
     skos:altLabel "Chg. Capacity(Ah)" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "A.h" ;
     schema:unitText "ampere hour"@en ;
     skos:definition "Instrument charge accumulator for current flowing into the cell (charge), in ampere hour. The accumulation window resets at schedule-authored boundaries (per cycle, at scripted steps, or never) that are not recoverable from the exported time-series alone, so it maps to the program-scoped core term bdf:schedule_charging_capacity_ah rather than a cycle- or step-scoped term. Decreases only at a reset, to zero. MITS 7 code PV23 (PV_ChargeCapacity)."@en ;
     rdfs:comment "Instrument charge accumulator for current flowing into the cell (charge), in ampere hour. The accumulation window resets at schedule-authored boundaries (per cycle, at scripted steps, or never) that are not recoverable from the exported time-series alone, so it maps to the program-scoped core term bdf:schedule_charging_capacity_ah rather than a cycle- or step-scoped term. Decreases only at a reset, to zero. MITS 7 code PV23 (PV_ChargeCapacity)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#discharging_capacity_ah
arbin:discharging_capacity_ah rdf:type owl:Class ;
     rdfs:subClassOf bdf:schedule_discharging_capacity_ah ;
     skos:exactMatch bdf:schedule_discharging_capacity_ah ;
     rdfs:label "Discharge Capacity"@en ;
     skos:prefLabel "Discharge Capacity"@en ;
     skos:altLabel "Discharge Capacity (Ah)" ;
     skos:altLabel "Discharge_Capacity(Ah)" ;
     skos:altLabel "Discharge Capacity(Ah)" ;
     skos:altLabel "Discharge_Capacity" ;
     skos:altLabel "DChg_Capacity(Ah)" ;
     skos:altLabel "DChg. Capacity(Ah)" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "A.h" ;
     schema:unitText "ampere hour"@en ;
     skos:definition "Instrument charge accumulator for current flowing out of the cell (discharge), in ampere hour, with schedule-authored reset windows not recoverable from the time-series; maps to bdf:schedule_discharging_capacity_ah. Decreases only at a reset, to zero. MITS 7 code PV24 (PV_DischargeCapacity)."@en ;
     rdfs:comment "Instrument charge accumulator for current flowing out of the cell (discharge), in ampere hour, with schedule-authored reset windows not recoverable from the time-series; maps to bdf:schedule_discharging_capacity_ah. Decreases only at a reset, to zero. MITS 7 code PV24 (PV_DischargeCapacity)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#charging_energy_wh
arbin:charging_energy_wh rdf:type owl:Class ;
     rdfs:subClassOf bdf:schedule_charging_energy_wh ;
     skos:exactMatch bdf:schedule_charging_energy_wh ;
     rdfs:label "Charge Energy"@en ;
     skos:prefLabel "Charge Energy"@en ;
     skos:altLabel "Charge Energy (Wh)" ;
     skos:altLabel "Charge_Energy(Wh)" ;
     skos:altLabel "Charge Energy(Wh)" ;
     skos:altLabel "Charge_Energy" ;
     skos:altLabel "Chg_Energy(Wh)" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "W.h" ;
     schema:unitText "watt hour"@en ;
     skos:definition "Instrument energy accumulator over the charge intervals, in watt hour, with schedule-authored reset windows not recoverable from the time-series; maps to bdf:schedule_charging_energy_wh. Decreases only at a reset, to zero. MITS 7 code PV25 (PV_ChargeEnergy)."@en ;
     rdfs:comment "Instrument energy accumulator over the charge intervals, in watt hour, with schedule-authored reset windows not recoverable from the time-series; maps to bdf:schedule_charging_energy_wh. Decreases only at a reset, to zero. MITS 7 code PV25 (PV_ChargeEnergy)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#discharging_energy_wh
arbin:discharging_energy_wh rdf:type owl:Class ;
     rdfs:subClassOf bdf:schedule_discharging_energy_wh ;
     skos:exactMatch bdf:schedule_discharging_energy_wh ;
     rdfs:label "Discharge Energy"@en ;
     skos:prefLabel "Discharge Energy"@en ;
     skos:altLabel "Discharge Energy (Wh)" ;
     skos:altLabel "Discharge_Energy(Wh)" ;
     skos:altLabel "Discharge Energy(Wh)" ;
     skos:altLabel "Discharge_Energy" ;
     skos:altLabel "DChg_Energy(Wh)" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "W.h" ;
     schema:unitText "watt hour"@en ;
     skos:definition "Instrument energy accumulator over the discharge intervals, in watt hour, with schedule-authored reset windows not recoverable from the time-series; maps to bdf:schedule_discharging_energy_wh. Decreases only at a reset, to zero. MITS 7 code PV26 (PV_DischargeEnergy)."@en ;
     rdfs:comment "Instrument energy accumulator over the discharge intervals, in watt hour, with schedule-authored reset windows not recoverable from the time-series; maps to bdf:schedule_discharging_energy_wh. Decreases only at a reset, to zero. MITS 7 code PV26 (PV_DischargeEnergy)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#capacity_ah
arbin:capacity_ah rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Capacity"@en ;
     skos:prefLabel "Capacity"@en ;
     skos:altLabel "Capacity (Ah)" ;
     skos:altLabel "Capacity(Ah)" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "A.h" ;
     schema:unitText "ampere hour"@en ;
     skos:scopeNote "Verified against shandong and melasta exports (~376k rows, zero negatives): equals the active-direction half-cycle accumulator and resets 1:1 with Step_Index. Semantics are schedule-window-defined, hence no test-, cycle- or step-scoped core mapping."@en ;
     skos:definition "Time-series 'Capacity (Ah)' accumulator of the space dialect: the magnitude of charge accumulated in whichever direction is currently active, in ampere hour. Verified unsigned (never negative) and equal to arbin:charging_capacity_ah during charge steps (current > 0) and to arbin:discharging_capacity_ah during discharge steps (current < 0), re-zeroing at schedule step boundaries (1:1 with Step_Index transitions). It is NOT signed net capacity and NOT charge minus discharge, so it does not map to bdf:net_capacity_ah; it is a vendor-only, schedule-window-scoped magnitude. Distinct from the Global_Info nominal Capacity (arbin:nominal_capacity_ah)."@en ;
     rdfs:comment "Time-series 'Capacity (Ah)' accumulator of the space dialect: the magnitude of charge accumulated in whichever direction is currently active, in ampere hour. Verified unsigned (never negative) and equal to arbin:charging_capacity_ah during charge steps (current > 0) and to arbin:discharging_capacity_ah during discharge steps (current < 0), re-zeroing at schedule step boundaries (1:1 with Step_Index transitions). It is NOT signed net capacity and NOT charge minus discharge, so it does not map to bdf:net_capacity_ah; it is a vendor-only, schedule-window-scoped magnitude. Distinct from the Global_Info nominal Capacity (arbin:nominal_capacity_ah)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#specific_capacity_mah_g
arbin:specific_capacity_mah_g rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Specific Capacity (time-series)"@en ;
     skos:prefLabel "Specific Capacity (time-series)"@en ;
     skos:altLabel "mAh/g" ;
     arbin:role "derived" ;
     arbin:sheetScope "timeseries" ;
     arbin:sheetScope "statistics" ;
     schema:unitCode "mA.h/g" ;
     schema:unitText "milliampere hour per gram"@en ;
     skos:definition "Per-gram rescaling of the time-series arbin:capacity_ah accumulator: capacity in ampere hour times 1000 divided by the active-material MASS (gram) from Global_Info, giving milliampere hour per gram. Verified as an exact rescaling of arbin:capacity_ah (not of the charge/discharge accumulators); it inherits capacity_ah's behaviour — unsigned and resetting in lock-step at schedule step boundaries. Zero throughout when MASS is undefined. Vendor-derived, no BDF core equivalent."@en ;
     rdfs:comment "Per-gram rescaling of the time-series arbin:capacity_ah accumulator: capacity in ampere hour times 1000 divided by the active-material MASS (gram) from Global_Info, giving milliampere hour per gram. Verified as an exact rescaling of arbin:capacity_ah (not of the charge/discharge accumulators); it inherits capacity_ah's behaviour — unsigned and resetting in lock-step at schedule step boundaries. Zero throughout when MASS is undefined. Vendor-derived, no BDF core equivalent."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#dv_dt
arbin:dv_dt rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Voltage Time Derivative"@en ;
     skos:prefLabel "Voltage Time Derivative"@en ;
     skos:altLabel "dV/dt (V/s)" ;
     skos:altLabel "dV/dt(V/s)" ;
     skos:altLabel "dV/dt" ;
     arbin:role "measurement" ;
     arbin:sheetScope "timeseries" ;
     schema:unitCode "V/s" ;
     schema:unitText "volt per second"@en ;
     skos:definition "Instrument-reported time derivative of voltage, in volt per second. MITS 7 code PV27 (PV_dVdt)."@en ;
     rdfs:comment "Instrument-reported time derivative of voltage, in volt per second. MITS 7 code PV27 (PV_dVdt)."@en .

###  https://w3id.org/battery-data-alliance/ontology/battery-data-format/vendors/arbin#dq_dv
arbin:dq_dv rdf:type owl:Class ;
     rdfs:subClassOf sosa:ObservableProperty ;
     rdfs:label "Incremental Capacity dQ/dV"@en ;
     skos:prefLabel "Incremental Capacity dQ/dV"@en ;
     skos:altLabel "dQ/dV (Ah/V)" ;
     arbin:role "derived" ;
     arbin:sheetScope "timeseries" ;
